<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Bilingual support: activate Arabic (Modern Standard Arabic)
         and add it to every website's allowed-language set so our
         in-navbar language switcher can route to /ar/... URLs.

         Odoo ships every res.lang already defined in the ``base``
         module — they're just deactivated. The supported way to turn
         one on from a module is ``res.lang._activate_lang(code)``,
         which flips ``active=True`` on the existing record and loads
         the gettext .po translations for that locale. Idempotent. -->

    <data>
        <!-- Step 1 — activate Arabic. The ``eval`` attribute on
             ``<function>`` provides the full positional-args tuple
             in a way the convert.py XML loader picks up reliably
             across Odoo versions. -->
        <function model="res.lang" name="_activate_lang" eval="('ar_001',)"/>

        <!-- Step 2 — add Arabic to every website's allowed-language
             set. ``website.language_ids`` is the relation Odoo's
             language router consults; without us in there, /ar/
             URLs 404. -->
        <function model="website" name="write">
            <function model="website" name="search">
                <value eval="[]"/>
            </function>
            <value eval="{'language_ids': [(4, ref('base.lang_ar_001'))]}"/>
        </function>
    </data>
</odoo>
