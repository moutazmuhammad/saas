<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <!-- OTP Verification Email for Registration -->
    <record id="mail_template_registration_otp" model="mail.template">
        <field name="name">SaaS: Registration Email Verification</field>
        <field name="model_id" ref="model_saas_registration_otp"/>
        <field name="subject">Your verification code: {{ object.code }}</field>
        <field name="email_from">{{ (object.env.company.email or 'noreply@example.com') }}</field>
        <field name="email_to">{{ object.identifier }}</field>
        <field name="body_html" type="html">
<div style="margin: 0; padding: 0; font-family: Arial, sans-serif;">
    <p>Welcome!</p>
    <p>Your email verification code is:</p>
    <div style="text-align: center; margin: 24px 0;">
        <span style="font-size: 32px; font-weight: bold; letter-spacing: 8px;
                     background: #f0f0f0; padding: 12px 24px; border-radius: 8px;
                     display: inline-block;">
            <t t-out="object.code"/>
        </span>
    </div>
    <p>This code expires in <strong>10 minutes</strong>.</p>
    <p>If you did not request this, please ignore this email.</p>
    <p>Best regards,<br/><t t-out="object.env.company.name"/></p>
</div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

</odoo>
