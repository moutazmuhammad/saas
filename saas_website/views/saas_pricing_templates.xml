<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="plans_page" name="SaaS Plans">
        <t t-call="website.layout">
            <t t-set="additional_title">Plans</t>

            <div class="container py-5">
                <div class="text-center mb-5">
                    <h1 class="display-5 fw-bold">Choose Your Plan</h1>
                    <p class="lead text-muted">
                        Get your own Odoo instance up and running in minutes.
                    </p>
                </div>

                <div class="row justify-content-center g-4">
                    <t t-foreach="plans" t-as="plan">
                        <div class="col-lg-4 col-md-6">
                            <div class="card h-100 shadow-sm border-0">
                                <div class="card-header bg-primary text-white text-center py-3">
                                    <h4 class="mb-0 fw-bold" t-field="plan.name"/>
                                </div>
                                <div class="card-body d-flex flex-column px-4 py-4">
                                    <!-- Price -->
                                    <div class="text-center mb-4">
                                        <span class="display-6 fw-bold">
                                            <t t-if="plan.currency_id">
                                                <t t-out="plan.currency_id.symbol"/>
                                            </t>
                                            <t t-out="int(plan.price) if plan.price == int(plan.price) else '%.2f' % plan.price"/>
                                        </span>
                                        <span class="text-muted">
                                            / <t t-if="plan.billing_period == 'monthly'">mo</t>
                                              <t t-if="plan.billing_period == 'yearly'">yr</t>
                                        </span>
                                    </div>

                                    <!-- Features -->
                                    <ul class="list-unstyled mb-4 flex-grow-1">
                                        <li class="mb-2">
                                            <i class="fa fa-microchip text-primary me-2"/>
                                            <strong t-out="plan.cpu_limit"/> CPU
                                            <t t-if="plan.cpu_limit == 1"> Core</t>
                                            <t t-else=""> Cores</t>
                                        </li>
                                        <li class="mb-2">
                                            <i class="fa fa-memory text-primary me-2"/>
                                            <t t-out="plan.ram_limit.upper() if plan.ram_limit else 'N/A'"/> RAM
                                        </li>
                                        <li class="mb-2">
                                            <i class="fa fa-hdd-o text-primary me-2"/>
                                            <t t-out="int(plan.storage_limit)"/> GB Storage
                                        </li>
                                        <li class="mb-2">
                                            <i class="fa fa-cloud-download text-primary me-2"/>
                                            <t t-out="plan.max_backups"/> Daily Backups
                                        </li>
                                    </ul>

                                    <!-- CTA -->
                                    <a t-attf-href="/plans/#{plan.id}/configure"
                                       class="btn btn-primary btn-lg w-100 mt-auto">
                                        Get Started
                                    </a>
                                    <a t-if="trial_available"
                                       t-attf-href="/plans/#{plan.id}/configure?trial=1"
                                       class="btn btn-outline-success w-100 mt-2">
                                        <i class="fa fa-gift me-1"/>
                                        Start Free Trial
                                        (<t t-out="trial_days"/> days)
                                    </a>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <t t-if="not plans">
                    <div class="text-center text-muted py-5">
                        <p class="lead">No plans available at the moment. Please check back later.</p>
                    </div>
                </t>
            </div>

        </t>
    </template>

</odoo>
