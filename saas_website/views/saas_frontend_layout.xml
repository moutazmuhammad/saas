<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Override Odoo's website header with CloudOdoo dark navbar.
         This applies to ALL website pages (services, portal, login,
         contact, etc.) so the entire site looks consistent.
         ============================================================ -->

    <template id="cloudodoo_header" name="CloudOdoo Header"
              inherit_id="website.layout" customize_show="False">
        <xpath expr="//header" position="replace">
            <header id="top" data-anchor="true">
                <nav class="navbar navbar-expand-lg navbar-dark fixed-top co-navbar">
                    <div class="container">
                        <a class="navbar-brand d-flex align-items-center" href="/">
                            <i class="fas fa-cloud me-2"></i>
                            <span class="fw-bold">CloudOdoo</span>
                        </a>
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#coNavbar">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="collapse navbar-collapse" id="coNavbar">
                            <ul class="navbar-nav ms-auto align-items-center">
                                <li class="nav-item">
                                    <a class="nav-link" href="/services">Services</a>
                                </li>

                                <!-- Logged-in user nav -->
                                <t t-if="not request.env.user._is_public()">
                                    <li class="nav-item">
                                        <a class="nav-link" href="/my/instances">My Instances</a>
                                    </li>
                                    <li class="nav-item dropdown ms-lg-3">
                                        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#"
                                           role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <div class="d-flex align-items-center justify-content-center rounded-circle me-2"
                                                 style="width:32px;height:32px;background:var(--co-primary, #0066FF);font-size:0.8rem;color:white;">
                                                <t t-esc="(request.env.user.name or 'U')[:2].upper()"/>
                                            </div>
                                            <span class="d-none d-lg-inline" t-esc="request.env.user.name"/>
                                        </a>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li><a class="dropdown-item" href="/my/home"><i class="fas fa-user me-2"></i>Profile</a></li>
                                            <li><a class="dropdown-item" href="/my/instances"><i class="fas fa-server me-2"></i>My Instances</a></li>
                                            <li t-if="request.env.user.has_group('base.group_user')">
                                                <a class="dropdown-item" href="/odoo"><i class="fas fa-cogs me-2"></i>Backend</a>
                                            </li>
                                            <li><hr class="dropdown-divider"/></li>
                                            <li><a class="dropdown-item text-danger" href="/web/session/logout?redirect=/"><i class="fas fa-sign-out-alt me-2"></i>Sign Out</a></li>
                                        </ul>
                                    </li>
                                </t>

                                <!-- Public user nav -->
                                <t t-if="request.env.user._is_public()">
                                    <li class="nav-item ms-lg-3">
                                        <a class="btn btn-outline-light btn-sm" href="/services/register">Sign Up</a>
                                    </li>
                                    <li class="nav-item ms-2">
                                        <a class="btn btn-primary btn-sm" href="/web/login">Sign In</a>
                                    </li>
                                </t>
                            </ul>
                        </div>
                    </div>
                </nav>
            </header>
        </xpath>
    </template>

    <!-- ============================================================
         Override Odoo's website footer with CloudOdoo dark footer.
         Removes "Powered by Odoo" branding.
         ============================================================ -->

    <template id="cloudodoo_footer" name="CloudOdoo Footer"
              inherit_id="website.layout" customize_show="False">
        <xpath expr="//footer" position="replace">
            <footer id="bottom" data-anchor="true" class="co-footer">
                <div class="container">
                    <div class="row g-4 py-4">
                        <div class="col-lg-4">
                            <div class="d-flex align-items-center mb-3">
                                <i class="fas fa-cloud me-2 fs-4" style="color:var(--co-primary, #0066FF);"></i>
                                <span class="fw-bold fs-5">CloudOdoo</span>
                            </div>
                            <p class="small mb-0" style="color:var(--co-text-muted, #71717A);">Enterprise cloud solutions powered by Odoo 18. Deploy, manage, and scale your business applications with ease.</p>
                        </div>
                        <div class="col-6 col-lg-2">
                            <h6 class="fw-bold mb-3">Product</h6>
                            <ul class="list-unstyled">
                                <li><a href="/services" class="co-footer-link">Services</a></li>
                                <li><a href="#" class="co-footer-link">Pricing</a></li>
                                <li><a href="#" class="co-footer-link">Features</a></li>
                            </ul>
                        </div>
                        <div class="col-6 col-lg-2">
                            <h6 class="fw-bold mb-3">Company</h6>
                            <ul class="list-unstyled">
                                <li><a href="#" class="co-footer-link">About</a></li>
                                <li><a href="#" class="co-footer-link">Blog</a></li>
                                <li><a href="#" class="co-footer-link">Careers</a></li>
                            </ul>
                        </div>
                        <div class="col-6 col-lg-2">
                            <h6 class="fw-bold mb-3">Support</h6>
                            <ul class="list-unstyled">
                                <li><a href="#" class="co-footer-link">Documentation</a></li>
                                <li><a href="#" class="co-footer-link">Help Center</a></li>
                                <li><a href="/contactus" class="co-footer-link">Contact</a></li>
                            </ul>
                        </div>
                        <div class="col-6 col-lg-2">
                            <h6 class="fw-bold mb-3">Legal</h6>
                            <ul class="list-unstyled">
                                <li><a href="#" class="co-footer-link">Privacy</a></li>
                                <li><a href="#" class="co-footer-link">Terms</a></li>
                                <li><a href="#" class="co-footer-link">Security</a></li>
                            </ul>
                        </div>
                    </div>
                    <hr class="my-2 border-secondary"/>
                    <div class="d-flex flex-wrap justify-content-between align-items-center py-3">
                        <p class="small mb-0" style="color:var(--co-text-muted, #71717A);">&#169; 2026 CloudOdoo. All rights reserved.</p>
                        <div class="d-flex gap-3">
                            <a href="#" style="color:var(--co-text-muted, #71717A);"><i class="fab fa-twitter"></i></a>
                            <a href="#" style="color:var(--co-text-muted, #71717A);"><i class="fab fa-linkedin"></i></a>
                            <a href="#" style="color:var(--co-text-muted, #71717A);"><i class="fab fa-github"></i></a>
                        </div>
                    </div>
                </div>
            </footer>
        </xpath>
    </template>

    <!-- ============================================================
         Remove Salesperson card from invoice portal page
         ============================================================ -->

    <template id="hide_invoice_salesperson" name="Hide Invoice Salesperson"
              inherit_id="account.portal_invoice_page" customize_show="False">
        <xpath expr="//div[@id='invoice_communication']" position="replace"/>
    </template>

    <!-- ============================================================
         Remove Salesperson + Communication from Sale Order page
         ============================================================ -->

    <template id="hide_so_salesperson" name="Hide SO Salesperson"
              inherit_id="sale.sale_order_portal_template" customize_show="False">
        <xpath expr="//div[@id='sale_order_communication']" position="replace"/>
    </template>

    <template id="hide_so_contact" name="Hide SO Contact"
              inherit_id="sale.sale_order_portal_template" customize_show="False">
        <xpath expr="//div[@t-if='sale_order.user_id']" position="replace"/>
    </template>

    <!-- ============================================================
         Remove Salesperson from invoice sidebar
         ============================================================ -->

    <template id="hide_invoice_contact" name="Hide Invoice Contact"
              inherit_id="account.portal_invoice_page" customize_show="False">
        <xpath expr="//div[@t-if='invoice.invoice_user_id']" position="replace"/>
    </template>

    <!-- ============================================================
         Remove "Powered by Odoo" everywhere — override the source
         templates to render nothing.
         ============================================================ -->

    <template id="hide_brand_message" name="Hide Brand Message"
              inherit_id="web.brand_promotion_message" customize_show="False">
        <xpath expr="//t[@t-set='odoo_logo']" position="replace"/>
        <xpath expr="//t[@t-set='final_message']" position="replace"/>
        <xpath expr="//t[@t-out]" position="replace"/>
    </template>

    <template id="hide_brand_promotion" name="Hide Brand Promotion"
              inherit_id="web.brand_promotion" customize_show="False">
        <xpath expr="//div[hasclass('o_brand_promotion')]" position="attributes">
            <attribute name="style">display:none !important;</attribute>
        </xpath>
    </template>

    <!-- Hide the copyright bar on all pages -->
    <template id="hide_copyright_bar" name="Hide Copyright Bar"
              inherit_id="web.frontend_layout" customize_show="False">
        <xpath expr="//footer[@id='bottom']" position="before">
            <t t-set="no_copyright" t-value="True"/>
        </xpath>
    </template>

    <!-- Remove "Powered by Odoo" from portal record sidebar
         (invoice detail, sale order detail, etc.) -->
    <template id="hide_portal_sidebar_branding" name="Hide Portal Sidebar Branding"
              inherit_id="portal.portal_record_sidebar" customize_show="False">
        <xpath expr="//div[hasclass('o_portal_sidebar_content')]/div[hasclass('text-muted')]" position="replace"/>
    </template>

    <!-- ============================================================
         Restyle portal side_content (user profile card on /my/home)
         ============================================================ -->

    <template id="cloudodoo_side_content" name="CloudOdoo Side Content"
              inherit_id="portal.side_content" customize_show="False">
        <!-- Replace the avatar + name block -->
        <xpath expr="//div[hasclass('d-flex','justify-content-start')]" position="replace">
            <div class="d-flex align-items-center gap-3 mb-3 pb-3" style="border-bottom:1px solid var(--border-color, #27272A);">
                <div class="d-flex align-items-center justify-content-center rounded-circle"
                     style="width:50px;height:50px;background:var(--co-primary, #0066FF);color:white;font-size:1.1rem;font-weight:600;flex-shrink:0;">
                    <t t-esc="(user_id.name or 'U')[:2].upper()"/>
                </div>
                <div>
                    <h5 class="mb-0" style="color:var(--co-text-primary, #FAFAFA);" t-out="user_id.name"/>
                    <p t-if="user_id.company_name" class="mb-0 small" style="color:var(--co-text-muted, #71717A);" t-out="user_id.company_name"/>
                </div>
            </div>
        </xpath>
        <!-- Replace the contact details widget with icon-based layout -->
        <xpath expr="//div[hasclass('o_portal_my_details')]" position="replace">
            <div class="o_portal_my_details d-flex flex-column gap-2">
                <t t-set="partner" t-value="user_id.partner_id"/>
                <t t-if="partner.email">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-envelope" style="width:18px;color:var(--co-text-muted, #71717A);font-size:0.85rem;"></i>
                        <a t-att-href="'mailto:' + partner.email" class="small text-break"
                           style="color:var(--co-primary, #0066FF);" t-esc="partner.email"/>
                    </div>
                </t>
                <t t-if="partner.phone">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-phone" style="width:18px;color:var(--co-text-muted, #71717A);font-size:0.85rem;"></i>
                        <span class="small" style="color:var(--co-text-secondary, #A1A1AA);" t-esc="partner.phone"/>
                    </div>
                </t>
                <t t-if="partner.city or partner.country_id">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-map-marker-alt" style="width:18px;color:var(--co-text-muted, #71717A);font-size:0.85rem;"></i>
                        <span class="small" style="color:var(--co-text-secondary, #A1A1AA);">
                            <t t-if="partner.city" t-esc="partner.city"/>
                            <t t-if="partner.city and partner.country_id">, </t>
                            <t t-if="partner.country_id" t-esc="partner.country_id.name"/>
                        </span>
                    </div>
                </t>
                <t t-if="partner.street">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-home" style="width:18px;color:var(--co-text-muted, #71717A);font-size:0.85rem;"></i>
                        <span class="small" style="color:var(--co-text-secondary, #A1A1AA);" t-esc="partner.street"/>
                    </div>
                </t>
            </div>
        </xpath>
        <!-- Replace the edit link with a styled button -->
        <xpath expr="//a[@href='/my/account']" position="replace">
            <a role="button" href="/my/account" class="btn btn-outline-light btn-sm w-100 mt-3">
                <i class="fas fa-pencil-alt me-1"></i> Edit Information
            </a>
        </xpath>
    </template>

    <!-- ============================================================
         CloudOdoo Layout — wrapper for our custom pages.
         Now just calls website.layout (which already has our
         overridden header/footer). No CDN needed since Odoo 18
         already provides Bootstrap 5.
         ============================================================ -->

    <template id="cloudodoo_layout" name="CloudOdoo Layout">
        <t t-call="website.layout">
            <t t-set="no_livechat" t-value="True"/>
            <div id="wrap" class="oe_structure">
                <t t-out="0"/>
            </div>
        </t>
    </template>

    <!-- ============================================================
         Home Page (Landing)
         ============================================================ -->

    <template id="cloudodoo_home" name="CloudOdoo Home">
        <t t-call="saas_website.cloudodoo_layout">
            <!-- Hero Section -->
            <section class="hero-section">
                <div class="hero-bg"></div>
                <div class="container position-relative">
                    <div class="row align-items-center min-vh-100 pt-5">
                        <div class="col-lg-6">
                            <h1 class="display-3 fw-bold mb-4">
                                Deploy Your Business<br/>
                                <span class="text-gradient">In Minutes</span>
                            </h1>
                            <p class="lead mb-4" style="color:var(--co-text-muted, #A1A1AA);">
                                Launch fully managed Odoo instances with enterprise-grade infrastructure.
                                ERP, CRM, Accounting, and more — all in the cloud.
                            </p>
                            <div class="d-flex flex-wrap gap-3">
                                <a href="/services" class="btn btn-primary btn-lg px-4">
                                    <i class="fas fa-rocket me-2"></i>Browse Services
                                </a>
                                <a href="#features" class="btn btn-outline-secondary btn-lg px-4">
                                    Learn More
                                </a>
                            </div>
                            <div class="mt-5 d-flex align-items-center gap-4">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    <span class="small" style="color:var(--co-text-muted, #A1A1AA);">Free Trial</span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    <span class="small" style="color:var(--co-text-muted, #A1A1AA);">No Credit Card</span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    <span class="small" style="color:var(--co-text-muted, #A1A1AA);">Instant Setup</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6 d-none d-lg-block">
                            <div class="hero-visual">
                                <div class="dashboard-preview">
                                    <div class="preview-header">
                                        <div class="preview-dots">
                                            <span></span><span></span><span></span>
                                        </div>
                                        <span class="preview-title">my-company.cloudodoo.com</span>
                                    </div>
                                    <div class="preview-body">
                                        <div class="preview-sidebar">
                                            <div class="sidebar-item active"><i class="fas fa-home"></i></div>
                                            <div class="sidebar-item"><i class="fas fa-users"></i></div>
                                            <div class="sidebar-item"><i class="fas fa-chart-bar"></i></div>
                                            <div class="sidebar-item"><i class="fas fa-cog"></i></div>
                                        </div>
                                        <div class="preview-content">
                                            <div class="stat-card">
                                                <span class="stat-value">$124,500</span>
                                                <span class="stat-label">Revenue</span>
                                            </div>
                                            <div class="stat-card">
                                                <span class="stat-value">1,247</span>
                                                <span class="stat-label">Customers</span>
                                            </div>
                                            <div class="stat-card">
                                                <span class="stat-value">98%</span>
                                                <span class="stat-label">Uptime</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Features Section -->
            <section id="features" class="py-6">
                <div class="container">
                    <div class="text-center mb-5">
                        <h2 class="display-5 fw-bold">Everything You Need</h2>
                        <p class="lead" style="color:var(--co-text-muted, #A1A1AA);">Enterprise-grade infrastructure without the complexity</p>
                    </div>
                    <div class="row g-4">
                        <div class="col-md-6 col-lg-3">
                            <div class="feature-card">
                                <div class="feature-icon"><i class="fas fa-server"></i></div>
                                <h5>Isolated Containers</h5>
                                <p class="small mb-0" style="color:var(--co-text-muted, #A1A1AA);">Each instance runs in its own Docker container with dedicated resources.</p>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="feature-card">
                                <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
                                <h5>Automatic Backups</h5>
                                <p class="small mb-0" style="color:var(--co-text-muted, #A1A1AA);">Daily automated backups with one-click restore capability.</p>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="feature-card">
                                <div class="feature-icon"><i class="fas fa-bolt"></i></div>
                                <h5>Instant Scaling</h5>
                                <p class="small mb-0" style="color:var(--co-text-muted, #A1A1AA);">Upgrade your plan anytime with zero downtime migrations.</p>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="feature-card">
                                <div class="feature-icon"><i class="fas fa-headset"></i></div>
                                <h5>24/7 Support</h5>
                                <p class="small mb-0" style="color:var(--co-text-muted, #A1A1AA);">Expert support team ready to help you succeed.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Stats Section -->
            <section class="py-6 bg-dark-gradient">
                <div class="container">
                    <div class="row text-center g-4">
                        <div class="col-6 col-lg-3">
                            <div class="stat-block">
                                <span class="stat-number">10K+</span>
                                <span class="stat-text">Active Instances</span>
                            </div>
                        </div>
                        <div class="col-6 col-lg-3">
                            <div class="stat-block">
                                <span class="stat-number">99.9%</span>
                                <span class="stat-text">Uptime SLA</span>
                            </div>
                        </div>
                        <div class="col-6 col-lg-3">
                            <div class="stat-block">
                                <span class="stat-number">50+</span>
                                <span class="stat-text">Countries</span>
                            </div>
                        </div>
                        <div class="col-6 col-lg-3">
                            <div class="stat-block">
                                <span class="stat-number">24/7</span>
                                <span class="stat-text">Support</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- CTA Section -->
            <section class="py-6">
                <div class="container">
                    <div class="cta-card text-center">
                        <h2 class="display-6 fw-bold mb-3">Ready to Get Started?</h2>
                        <p class="mb-4" style="color:var(--co-text-muted, #A1A1AA);">Start your free trial today. No credit card required.</p>
                        <a href="/services" class="btn btn-primary btn-lg px-5">
                            <i class="fas fa-rocket me-2"></i>Start Free Trial
                        </a>
                    </div>
                </div>
            </section>
        </t>
    </template>

</odoo>
