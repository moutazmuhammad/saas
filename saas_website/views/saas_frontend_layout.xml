<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         White-label: replace the `<meta name="generator" content="Odoo">`
         that website.layout injects on every QWeb-rendered page (checkout,
         /my/invoices, etc.) so the source no longer fingerprints the
         underlying stack. The SPA shell at `/` and other `spa_shell()`
         routes never include this meta — they ship a plain HTML doc — so
         this only affects the legacy Odoo-rendered pages.
         ============================================================ -->

    <template id="veltnex_hide_generator" name="VELTNEX: Hide Generator"
              inherit_id="website.layout" customize_show="False">
        <xpath expr="//meta[@name='generator']" position="attributes">
            <attribute name="content">VELTNEX</attribute>
        </xpath>
    </template>

    <!-- ============================================================
         Inject early theme script to prevent FOUC (flash of wrong theme).
         Runs synchronously before CSS paints.
         ============================================================ -->

    <template id="cloudodoo_theme_init" name="CloudOdoo Theme Init"
              inherit_id="web.frontend_layout" customize_show="False">
        <xpath expr="//head" position="inside">
            <!--
                Apply the user's theme BEFORE CSS paints so there's no
                flash. Uses the same localStorage key as the SPA
                (`veltnex-theme`) so toggling theme in the SPA is
                reflected on QWeb-rendered pages (checkout, /my/invoices,
                portal, etc.) and vice versa.
            -->
            <script>
                (function(){
                    try {
                        var t = localStorage.getItem('veltnex-theme');
                        if (t !== 'light' &amp;&amp; t !== 'dark') {
                            t = (window.matchMedia &amp;&amp; window.matchMedia('(prefers-color-scheme: light)').matches)
                                ? 'light' : 'dark';
                        }
                        document.documentElement.setAttribute('data-theme', t);
                        document.documentElement.classList.toggle('dark', t === 'dark');
                    } catch (e) {
                        document.documentElement.setAttribute('data-theme', 'dark');
                        document.documentElement.classList.add('dark');
                    }
                })();
            </script>
            <link rel="icon" type="image/svg+xml" href="/saas_website/static/src/img/veltnex-icon.svg"/>
            <link rel="shortcut icon" href="/saas_website/static/src/img/veltnex-icon.svg"/>
            <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" as="style"/>
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css"/>
        </xpath>
    </template>

    <!-- ============================================================
         Override Odoo's website header with CloudOdoo dark navbar.
         This applies to ALL website pages (services, portal, login,
         contact, etc.) so the entire site looks consistent.
         ============================================================ -->

    <template id="cloudodoo_header" name="CloudOdoo Header"
              inherit_id="website.layout" customize_show="False">
        <xpath expr="//header" position="replace">
            <!-- Section visibility flags. Unset / 'True' => shown.
                 Default-on so a fresh install behaves like before. -->
            <t t-set="show_services_section"
               t-value="request.env['ir.config_parameter'].sudo().get_param('saas_master.show_services_section', 'True') != 'False'"/>
            <t t-set="show_hosting_section"
               t-value="request.env['ir.config_parameter'].sudo().get_param('saas_master.show_hosting_section', 'True') != 'False'"/>
            <header id="top" data-anchor="true">
                <nav class="navbar navbar-expand-lg fixed-top co-navbar">
                    <div class="container">
                        <a class="navbar-brand d-flex align-items-center" href="/">
                            <img src="/saas_website/static/src/img/veltnex-icon.svg" alt="VELTNEX" style="height:30px;" class="me-2"/>
                            <span class="fw-bold">VELT<span style="color:#3656b8;">NEX</span></span>
                        </a>
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#coNavbar">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="collapse navbar-collapse" id="coNavbar">
                            <!-- Left group: nav links sit next to the logo
                                 (matches the VELTNEX SPA home page). -->
                            <ul class="navbar-nav me-auto align-items-center">
                                <li t-if="show_services_section" class="nav-item">
                                    <a class="nav-link" href="/services">Services</a>
                                </li>
                                <li t-if="show_hosting_section" class="nav-item">
                                    <a class="nav-link" href="/hosting">Hosting</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/docs">Docs</a>
                                </li>
                            </ul>
                            <!-- Right group: account dropdown / auth buttons. -->
                            <ul class="navbar-nav align-items-center">
                                <!-- Logged-in user nav. The standalone
                                     "My Instances" link is intentionally
                                     not in the top bar — it lives inside
                                     the profile dropdown below so the
                                     header stays uncluttered. -->
                                <t t-if="not request.env.user._is_public()">
                                    <li class="nav-item dropdown ms-lg-3">
                                        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#"
                                           role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <div class="d-flex align-items-center justify-content-center rounded-circle me-2"
                                                 style="width:32px;height:32px;background:var(--co-primary, #203c86);font-size:0.8rem;color:white;">
                                                <t t-esc="(request.env.user.name or 'U')[:2].upper()"/>
                                            </div>
                                            <span class="d-none d-lg-inline" t-esc="request.env.user.name"/>
                                        </a>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li><a class="dropdown-item" href="/my"><i class="fas fa-th-large me-2"></i>Dashboard</a></li>
                                            <li><a class="dropdown-item" href="/my/account"><i class="fas fa-user me-2"></i>Profile</a></li>
                                            <li><a class="dropdown-item" href="/my/instances"><i class="fas fa-server me-2"></i>My Instances</a></li>
                                            <li t-if="request.env.user.has_group('base.group_user')">
                                                <a class="dropdown-item" href="/odoo"><i class="fas fa-cogs me-2"></i>Backend</a>
                                            </li>
                                            <li><hr class="dropdown-divider"/></li>
                                            <li><a class="dropdown-item text-danger" href="/web/session/logout?redirect=/"><i class="fas fa-sign-out-alt me-2"></i>Sign Out</a></li>
                                        </ul>
                                    </li>
                                </t>

                                <!-- Public user nav (matches the VELTNEX SPA) -->
                                <t t-if="request.env.user._is_public()">
                                    <li class="nav-item ms-lg-3">
                                        <a class="nav-link" href="/login">Sign in</a>
                                    </li>
                                    <li class="nav-item ms-2">
                                        <a class="btn btn-primary btn-sm" href="/services/register">Get started</a>
                                    </li>
                                </t>
                            </ul>
                        </div>
                    </div>
                </nav>
            </header>
        </xpath>
    </template>

    <!-- ============================================================
         Override Odoo's website footer with CloudOdoo dark footer.
         Removes "Powered by Odoo" branding.
         ============================================================ -->

    <template id="cloudodoo_footer" name="CloudOdoo Footer"
              inherit_id="website.layout" customize_show="False">
        <xpath expr="//footer" position="replace">
            <t t-set="show_services_section"
               t-value="request.env['ir.config_parameter'].sudo().get_param('saas_master.show_services_section', 'True') != 'False'"/>
            <t t-set="show_hosting_section"
               t-value="request.env['ir.config_parameter'].sudo().get_param('saas_master.show_hosting_section', 'True') != 'False'"/>
            <footer id="bottom" data-anchor="true" class="co-footer">
                <div class="container">
                    <div class="row g-4 py-5">
                        <div class="col-12 col-lg-3">
                            <a href="/" class="d-flex align-items-center mb-3 text-decoration-none">
                                <img src="/saas_website/static/src/img/veltnex-icon.svg" alt="VELTNEX" style="height:30px;" class="me-2"/>
                                <span class="fw-bold fs-5" style="color:var(--co-text-primary, #FAFAFA);">VELT<span style="color:#3656b8;">NEX</span></span>
                            </a>
                            <p class="small mb-4" style="color:var(--co-text-muted, #71717A);max-width:22rem;">The Logic of Stability. Enterprise-grade managed hosting for Odoo, built for teams that can't afford downtime.</p>
                            <div class="d-flex gap-2">
                                <a href="#" class="co-social" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                                <a href="#" class="co-social" aria-label="GitHub"><i class="fab fa-github"></i></a>
                                <a href="#" class="co-social" aria-label="LinkedIn"><i class="fab fa-linkedin"></i></a>
                            </div>
                        </div>
                        <div class="col-6 col-lg-3">
                            <h6 class="fw-bold mb-3">Product</h6>
                            <ul class="list-unstyled">
                                <li t-if="show_services_section"><a href="/services" class="co-footer-link">Services</a></li>
                                <li t-if="show_hosting_section"><a href="/hosting" class="co-footer-link">Hosting</a></li>
                                <li t-if="show_hosting_section"><a href="/hosting/configure" class="co-footer-link">Configure</a></li>
                                <li><a href="/docs" class="co-footer-link">Docs</a></li>
                            </ul>
                        </div>
                        <div class="col-6 col-lg-3">
                            <h6 class="fw-bold mb-3">Company</h6>
                            <ul class="list-unstyled">
                                <li><a href="#" class="co-footer-link">About</a></li>
                                <li><a href="#" class="co-footer-link">Customers</a></li>
                                <li><a href="#" class="co-footer-link">Careers</a></li>
                                <li><a href="/contactus" class="co-footer-link">Contact</a></li>
                            </ul>
                        </div>
                        <div class="col-6 col-lg-3">
                            <h6 class="fw-bold mb-3">Account</h6>
                            <ul class="list-unstyled">
                                <li><a href="/login" class="co-footer-link">Sign in</a></li>
                                <li><a href="/services/register" class="co-footer-link">Get started</a></li>
                                <li><a href="/my" class="co-footer-link">Dashboard</a></li>
                                <li><a href="/my/billing" class="co-footer-link">Invoices</a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2 py-4"
                         style="border-top:1px solid var(--border-color, #27272A);">
                        <p class="small mb-0" style="color:var(--co-text-muted, #71717A);">&#169; 2026 VELTNEX, Inc. All rights reserved.</p>
                        <p class="small mb-0" style="color:var(--co-text-muted, #71717A);">Status: <span style="color:#10B981;">All systems operational</span></p>
                    </div>
                </div>
            </footer>
        </xpath>
    </template>

    <!-- ============================================================
         Remove Salesperson card from invoice portal page
         ============================================================ -->

    <template id="hide_invoice_salesperson" name="Hide Invoice Salesperson"
              inherit_id="account.portal_invoice_page" customize_show="False">
        <xpath expr="//div[@id='invoice_communication']" position="replace"/>
    </template>

    <!-- ============================================================
         Remove Salesperson + Communication from Sale Order page
         ============================================================ -->

    <template id="hide_so_salesperson" name="Hide SO Salesperson"
              inherit_id="sale.sale_order_portal_template" customize_show="False">
        <xpath expr="//div[@id='sale_order_communication']" position="replace"/>
    </template>

    <template id="hide_so_contact" name="Hide SO Contact"
              inherit_id="sale.sale_order_portal_template" customize_show="False">
        <xpath expr="//div[@t-if='sale_order.user_id']" position="replace"/>
    </template>

    <!-- ============================================================
         Remove Salesperson from invoice sidebar
         ============================================================ -->

    <template id="hide_invoice_contact" name="Hide Invoice Contact"
              inherit_id="account.portal_invoice_page" customize_show="False">
        <xpath expr="//div[@t-if='invoice.invoice_user_id']" position="replace"/>
    </template>

    <!-- ============================================================
         Remove "Powered by Odoo" everywhere — override the source
         templates to render nothing.
         ============================================================ -->

    <template id="hide_brand_message" name="Hide Brand Message"
              inherit_id="web.brand_promotion_message" customize_show="False">
        <xpath expr="//t[@t-set='odoo_logo']" position="replace"/>
        <xpath expr="//t[@t-set='final_message']" position="replace"/>
        <xpath expr="//t[@t-out]" position="replace"/>
    </template>

    <template id="hide_brand_promotion" name="Hide Brand Promotion"
              inherit_id="web.brand_promotion" customize_show="False">
        <xpath expr="//div[hasclass('o_brand_promotion')]" position="attributes">
            <attribute name="style">display:none !important;</attribute>
        </xpath>
    </template>

    <!-- Hide the copyright bar on all pages -->
    <template id="hide_copyright_bar" name="Hide Copyright Bar"
              inherit_id="web.frontend_layout" customize_show="False">
        <xpath expr="//footer[@id='bottom']" position="before">
            <t t-set="no_copyright" t-value="True"/>
        </xpath>
    </template>

    <!-- Remove "Powered by Odoo" from portal record sidebar
         (invoice detail, sale order detail, etc.) -->
    <template id="hide_portal_sidebar_branding" name="Hide Portal Sidebar Branding"
              inherit_id="portal.portal_record_sidebar" customize_show="False">
        <xpath expr="//div[hasclass('o_portal_sidebar_content')]/div[hasclass('text-muted')]" position="replace"/>
    </template>

    <!-- ============================================================
         Restyle portal side_content (user profile card on /my/home)
         ============================================================ -->

    <template id="cloudodoo_side_content" name="CloudOdoo Side Content"
              inherit_id="portal.side_content" customize_show="False">
        <!-- Replace the avatar + name block -->
        <xpath expr="//div[hasclass('d-flex','justify-content-start')]" position="replace">
            <div class="d-flex align-items-center gap-3 mb-3 pb-3" style="border-bottom:1px solid var(--border-color, #27272A);">
                <div class="d-flex align-items-center justify-content-center rounded-circle"
                     style="width:50px;height:50px;background:var(--co-primary, #203c86);color:white;font-size:1.1rem;font-weight:600;flex-shrink:0;">
                    <t t-esc="(user_id.name or 'U')[:2].upper()"/>
                </div>
                <div>
                    <h5 class="mb-0" style="color:var(--co-text-primary, #FAFAFA);" t-out="user_id.name"/>
                    <p t-if="user_id.company_name" class="mb-0 small" style="color:var(--co-text-muted, #71717A);" t-out="user_id.company_name"/>
                </div>
            </div>
        </xpath>
        <!-- Replace the contact details widget with icon-based layout -->
        <xpath expr="//div[hasclass('o_portal_my_details')]" position="replace">
            <div class="o_portal_my_details d-flex flex-column gap-2">
                <t t-set="partner" t-value="user_id.partner_id"/>
                <t t-if="partner.email">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-envelope" style="width:18px;color:var(--co-text-muted, #71717A);font-size:0.85rem;"></i>
                        <a t-att-href="'mailto:' + partner.email" class="small text-break"
                           style="color:var(--co-primary, #203c86);" t-esc="partner.email"/>
                    </div>
                </t>
                <t t-if="partner.phone">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-phone" style="width:18px;color:var(--co-text-muted, #71717A);font-size:0.85rem;"></i>
                        <span class="small" style="color:var(--co-text-secondary, #A1A1AA);" t-esc="partner.phone"/>
                    </div>
                </t>
                <t t-if="partner.city or partner.country_id">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-map-marker-alt" style="width:18px;color:var(--co-text-muted, #71717A);font-size:0.85rem;"></i>
                        <span class="small" style="color:var(--co-text-secondary, #A1A1AA);">
                            <t t-if="partner.city" t-esc="partner.city"/>
                            <t t-if="partner.city and partner.country_id">, </t>
                            <t t-if="partner.country_id" t-esc="partner.country_id.name"/>
                        </span>
                    </div>
                </t>
                <t t-if="partner.street">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-home" style="width:18px;color:var(--co-text-muted, #71717A);font-size:0.85rem;"></i>
                        <span class="small" style="color:var(--co-text-secondary, #A1A1AA);" t-esc="partner.street"/>
                    </div>
                </t>
            </div>
        </xpath>
        <!-- Replace the edit link with a styled button -->
        <xpath expr="//a[@href='/my/account']" position="replace">
            <a role="button" href="/my/account" class="btn btn-outline-light btn-sm w-100 mt-3">
                <i class="fas fa-pencil-alt me-1"></i> Edit Information
            </a>
        </xpath>
    </template>

    <!-- ============================================================
         CloudOdoo Layout — wrapper for our custom pages.
         Now just calls website.layout (which already has our
         overridden header/footer). No CDN needed since Odoo 18
         already provides Bootstrap 5.
         ============================================================ -->

    <template id="cloudodoo_layout" name="CloudOdoo Layout">
        <t t-call="website.layout">
            <t t-set="no_livechat" t-value="True"/>
            <div id="wrap" class="oe_structure">
                <t t-out="0"/>
            </div>
        </t>
    </template>

    <!-- ============================================================
         Home Page (Landing)
         ============================================================ -->


</odoo>
