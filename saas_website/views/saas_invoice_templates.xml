<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Override Invoice Portal Page — replace iframe with themed content
         ============================================================ -->

    <template id="portal_invoice_page_override" name="CloudOdoo Invoice Page"
              inherit_id="account.portal_invoice_page" customize_show="False">

        <!-- Remove the o_portal_invoice_sidebar class to prevent the iframe JS widget from binding -->
        <xpath expr="//div[hasclass('o_portal_invoice_sidebar')]" position="attributes">
            <attribute name="class">row</attribute>
        </xpath>

        <!-- Replace the iframe content area with direct themed rendering -->
        <xpath expr="//div[@id='invoice_content']" position="replace">
            <div id="invoice_content" class="o_portal_content col-12 col-lg-8 col-xxl-9">
                <t t-if="error or warning" t-call="account.portal_invoice_error"/>
                <t t-if="success and (not error and not warning)" t-call="account.portal_invoice_success"/>

                <!-- Invoice header -->
                <div class="card mb-3" style="background:var(--bg-card);border-color:var(--border-color);">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                            <div>
                                <h3 class="mb-1" style="color:var(--text-primary);">
                                    <t t-if="invoice.move_type == 'out_invoice'">Invoice</t>
                                    <t t-elif="invoice.move_type == 'out_refund'">Credit Note</t>
                                    <t t-elif="invoice.move_type == 'in_invoice'">Vendor Bill</t>
                                    <t t-elif="invoice.move_type == 'in_refund'">Refund</t>
                                    <t t-else="">Document</t>
                                    <span t-field="invoice.name"/>
                                </h3>
                                <div style="color:var(--text-muted);font-size:0.9rem;">
                                    <span>Date: </span>
                                    <span t-field="invoice.invoice_date"/>
                                    <t t-if="invoice.invoice_date_due">
                                        <span class="mx-2">|</span>
                                        <span>Due: </span>
                                        <span t-field="invoice.invoice_date_due"/>
                                    </t>
                                </div>
                            </div>
                            <div>
                                <span t-if="invoice.payment_state == 'paid'"
                                      class="badge fs-6" style="background:var(--success-light);color:var(--success);">
                                    <i class="fas fa-check-circle me-1"></i>Paid
                                </span>
                                <span t-elif="invoice.payment_state == 'partial'"
                                      class="badge fs-6" style="background:var(--warning-light);color:var(--warning);">
                                    <i class="fas fa-clock me-1"></i>Partially Paid
                                </span>
                                <span t-elif="invoice.payment_state == 'in_payment'"
                                      class="badge fs-6" style="background:rgba(59,130,246,0.1);color:var(--info);">
                                    <i class="fas fa-spinner me-1"></i>In Payment
                                </span>
                                <span t-elif="invoice.payment_state == 'reversed'"
                                      class="badge fs-6" style="background:var(--danger-light);color:var(--danger);">
                                    <i class="fas fa-undo me-1"></i>Reversed
                                </span>
                                <span t-else=""
                                      class="badge fs-6" style="background:var(--warning-light);color:var(--warning);">
                                    <i class="fas fa-exclamation-circle me-1"></i>Not Paid
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Invoice lines -->
                <div class="card mb-3" style="background:var(--bg-card);border-color:var(--border-color);">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table mb-0" style="color:var(--text-primary);">
                                <thead>
                                    <tr style="background:var(--bg-elevated);">
                                        <th style="border-color:var(--border-color);padding:0.75rem 1rem;color:var(--text-muted);font-weight:500;font-size:0.85rem;">Description</th>
                                        <th class="text-end" style="border-color:var(--border-color);padding:0.75rem 1rem;color:var(--text-muted);font-weight:500;font-size:0.85rem;">Quantity</th>
                                        <th class="text-end" style="border-color:var(--border-color);padding:0.75rem 1rem;color:var(--text-muted);font-weight:500;font-size:0.85rem;">Unit Price</th>
                                        <th class="text-end" style="border-color:var(--border-color);padding:0.75rem 1rem;color:var(--text-muted);font-weight:500;font-size:0.85rem;" t-if="display_discount">Disc.%</th>
                                        <th class="text-end" style="border-color:var(--border-color);padding:0.75rem 1rem;color:var(--text-muted);font-weight:500;font-size:0.85rem;">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="display_discount" t-value="any(l.discount for l in invoice.invoice_line_ids)"/>
                                    <t t-foreach="invoice.invoice_line_ids.filtered(lambda l: not l.display_type or l.display_type == 'product')" t-as="line">
                                        <tr>
                                            <td style="border-color:var(--border-color);padding:0.75rem 1rem;">
                                                <t t-esc="line.name"/>
                                            </td>
                                            <td class="text-end" style="border-color:var(--border-color);padding:0.75rem 1rem;">
                                                <t t-esc="line.quantity"/>
                                            </td>
                                            <td class="text-end" style="border-color:var(--border-color);padding:0.75rem 1rem;">
                                                <span t-field="line.price_unit"/>
                                            </td>
                                            <td class="text-end" style="border-color:var(--border-color);padding:0.75rem 1rem;" t-if="display_discount">
                                                <t t-if="line.discount">
                                                    <t t-esc="'%.0f' % line.discount"/>%
                                                </t>
                                            </td>
                                            <td class="text-end" style="border-color:var(--border-color);padding:0.75rem 1rem;font-weight:600;">
                                                <span t-field="line.price_subtotal"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Totals -->
                <div class="card mb-3" style="background:var(--bg-card);border-color:var(--border-color);">
                    <div class="card-body">
                        <div class="row justify-content-end">
                            <div class="col-md-5">
                                <table class="table table-sm mb-0" style="color:var(--text-primary);">
                                    <tbody>
                                        <tr>
                                            <td style="border:none;padding:0.4rem 0;color:var(--text-muted);">Subtotal</td>
                                            <td class="text-end" style="border:none;padding:0.4rem 0;">
                                                <span t-field="invoice.amount_untaxed"/>
                                            </td>
                                        </tr>
                                        <t t-if="invoice.amount_tax">
                                            <tr>
                                                <td style="border:none;padding:0.4rem 0;color:var(--text-muted);">Tax</td>
                                                <td class="text-end" style="border:none;padding:0.4rem 0;">
                                                    <span t-field="invoice.amount_tax"/>
                                                </td>
                                            </tr>
                                        </t>
                                        <tr style="border-top:2px solid var(--border-color);">
                                            <td style="padding:0.6rem 0;font-weight:700;font-size:1.1rem;">Total</td>
                                            <td class="text-end" style="padding:0.6rem 0;font-weight:700;font-size:1.1rem;">
                                                <span t-field="invoice.amount_total"/>
                                            </td>
                                        </tr>
                                        <t t-if="invoice.amount_residual and invoice.amount_residual != invoice.amount_total">
                                            <tr>
                                                <td style="border:none;padding:0.4rem 0;color:var(--warning);">Amount Due</td>
                                                <td class="text-end" style="border:none;padding:0.4rem 0;color:var(--warning);font-weight:600;">
                                                    <span t-field="invoice.amount_residual"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Download PDF button -->
                <div class="mb-4">
                    <a class="btn btn-outline-secondary"
                       t-att-href="invoice.get_portal_url(report_type='pdf', download=True)">
                        <i class="fas fa-download me-2"></i>Download PDF
                    </a>
                </div>

                <!-- Communication history -->
                <div id="invoice_communication" class="mt-4">
                    <h3 style="color:var(--text-primary);">Communication history</h3>
                    <t t-call="portal.message_thread"/>
                </div>
            </div>
        </xpath>
    </template>

</odoo>
