<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="plan_configure_form" name="Configure Your Instance">
        <t t-call="website.layout">
            <t t-set="additional_title">Configure Instance</t>

            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8">

                        <!-- Plan Summary -->
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body d-flex align-items-center">
                                <div class="flex-grow-1">
                                    <h5 class="mb-1">
                                        Plan: <strong t-field="plan.name"/>
                                    </h5>
                                    <span class="text-muted">
                                        <t t-if="plan.currency_id" t-out="plan.currency_id.symbol"/>
                                        <t t-out="'%.2f' % plan.price"/> / mo
                                        <span class="mx-2">|</span>
                                        <t t-out="plan.cpu_limit"/> CPU,
                                        <t t-out="plan.ram_limit"/> RAM,
                                        <t t-out="int(plan.storage_limit)"/> GB Storage
                                    </span>
                                </div>
                                <a href="/plans" class="btn btn-outline-secondary btn-sm">Change Plan</a>
                            </div>
                        </div>

                        <!-- Error message -->
                        <div t-if="error" class="alert alert-danger" role="alert">
                            <t t-out="error"/>
                        </div>

                        <!-- Configuration Form -->
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white">
                                <h4 class="mb-0">Configure Your Instance</h4>
                            </div>
                            <div class="card-body">
                                <form action="/plans/order" method="POST">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="plan_id"
                                           t-att-value="plan.id"/>
                                    <input t-if="is_trial" type="hidden"
                                           name="is_trial" value="1"/>

                                    <!-- Subdomain -->
                                    <div class="mb-4">
                                        <label for="subdomain" class="form-label fw-bold">
                                            Subdomain
                                        </label>
                                        <div class="input-group">
                                            <input type="text" name="subdomain" id="subdomain"
                                                   class="form-control form-control-lg"
                                                   placeholder="your-company"
                                                   required="required"
                                                   pattern="[a-z0-9]([a-z0-9\-]{0,61}[a-z0-9])?"
                                                   t-att-value="form_values.get('subdomain', '')"
                                                   autocomplete="off"/>
                                            <span class="input-group-text" id="domain-suffix">
                                                .<t t-if="domains" t-out="domains[0].name"/>
                                            </span>
                                        </div>
                                        <div id="subdomain-feedback" class="form-text"></div>
                                        <small class="text-muted">
                                            Lowercase letters, digits, and hyphens only.
                                        </small>
                                    </div>

                                    <!-- Base Domain -->
                                    <div class="mb-4">
                                        <label for="domain_id" class="form-label fw-bold">
                                            Base Domain
                                        </label>
                                        <select name="domain_id" id="domain_id"
                                                class="form-select" required="required">
                                            <t t-foreach="domains" t-as="domain">
                                                <option t-att-value="domain.id"
                                                        t-att-selected="str(domain.id) == str(form_values.get('domain_id', domains[0].id if domains else ''))">
                                                    <t t-out="domain.name"/>
                                                </option>
                                            </t>
                                        </select>
                                    </div>

                                    <!-- Submit -->
                                    <button t-if="is_trial" type="submit"
                                            class="btn btn-success btn-lg w-100">
                                        <i class="fa fa-gift me-2"/>Start Free Trial
                                    </button>
                                    <button t-else="" type="submit"
                                            class="btn btn-primary btn-lg w-100">
                                        <i class="fa fa-lock me-2"/>Continue to Payment
                                    </button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </t>
    </template>

</odoo>
