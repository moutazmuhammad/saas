<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Hosting Landing Page  —  /hosting
         ============================================================ -->

    <template id="hosting_page" name="Cloud Hosting">
        <t t-call="saas_website.cloudodoo_layout">
            <section class="py-6" style="padding-top:120px;">
                <div class="container">
                    <!-- Hero -->
                    <div class="text-center mb-5">
                        <h1 class="display-4 fw-bold mb-3">
                            <i class="fas fa-server me-3" style="color:var(--co-primary,#203c86);"></i>Cloud Hosting
                        </h1>
                        <p class="lead text-muted mx-auto" style="max-width:650px;">
                            Run your own Odoo project on our managed cloud.
                            Connect your repository, choose your resources, and we handle the rest.
                        </p>
                    </div>

                    <!-- Feature highlights -->
                    <div class="row g-4 mb-5">
                        <div class="col-md-3 col-6">
                            <div class="info-card text-center p-4">
                                <i class="fas fa-code-branch mb-3" style="font-size:2rem;color:var(--co-primary,#203c86);"></i>
                                <h6>Your Project</h6>
                                <p class="small text-muted mb-0">Connect your own repository</p>
                            </div>
                        </div>
                        <div class="col-md-3 col-6">
                            <div class="info-card text-center p-4">
                                <i class="fas fa-sync-alt mb-3" style="font-size:2rem;color:var(--success);"></i>
                                <h6>Auto-Deploy</h6>
                                <p class="small text-muted mb-0">Push your code, we update instantly</p>
                            </div>
                        </div>
                        <div class="col-md-3 col-6">
                            <div class="info-card text-center p-4">
                                <i class="fas fa-chart-line mb-3" style="font-size:2rem;color:var(--warning);"></i>
                                <h6>Monitoring</h6>
                                <p class="small text-muted mb-0">Live logs and resource usage</p>
                            </div>
                        </div>
                        <div class="col-md-3 col-6">
                            <div class="info-card text-center p-4">
                                <i class="fas fa-shield-alt mb-3" style="font-size:2rem;color:var(--info);"></i>
                                <h6>Backups</h6>
                                <p class="small text-muted mb-0">Automatic daily backups</p>
                            </div>
                        </div>
                    </div>

                    <!-- Trial Banner -->
                    <t t-if="trial_available">
                        <div class="trial-banner">
                            <div class="d-md-flex align-items-center justify-content-between">
                                <div class="mb-3 mb-md-0">
                                    <h5 class="mb-1"><i class="fas fa-gift me-2"></i>Start with a Free Trial</h5>
                                    <p class="mb-0 text-muted">
                                        Try hosting for <t t-esc="trial_days"/> days free. No credit card required.
                                    </p>
                                </div>
                                <a href="/hosting/configure?is_trial=1" class="btn btn-success">
                                    <i class="fas fa-rocket me-2"></i>Start Free Trial
                                </a>
                            </div>
                        </div>
                    </t>

                    <!-- Odoo Version Selection -->
                    <div class="text-center mb-4">
                        <label class="form-label fw-semibold" style="font-size:1rem;">Select Odoo Version</label>
                        <div>
                            <select id="hosting-version-select" class="form-select"
                                    style="width:auto;display:inline-block;min-width:200px;">
                                <t t-foreach="versions" t-as="ver">
                                    <option t-att-value="ver.id" t-esc="'Odoo %s' % ver.name"/>
                                </t>
                                <t t-if="not versions">
                                    <option value="">No hosting versions available</option>
                                </t>
                            </select>
                        </div>
                    </div>

                    <!-- Custom Plan Builder -->
                    <div class="custom-builder-section">
                        <div class="custom-builder-card">
                            <!-- Billing Toggle -->
                            <div class="text-center mb-4" id="hosting-billing-toggle">
                                <div class="billing-toggle">
                                    <button class="toggle-btn active" data-billing="monthly">Monthly</button>
                                    <button class="toggle-btn" data-billing="yearly">
                                        Yearly <span class="yearly-badge">Save <t t-esc="hosting_config.get('yearly_discount_pct', 20)"/>%</span>
                                    </button>
                                </div>
                            </div>

                            <div class="row g-4">
                                <!-- Left: Sliders -->
                                <div class="col-lg-7">
                                    <div class="slider-group" id="hosting-workers-slider-group">
                                        <div class="slider-header">
                                            <div class="slider-label">
                                                <i class="fas fa-cogs me-2"></i>Workers
                                            </div>
                                            <div class="slider-value" id="hosting-workers-value">
                                                <input type="number" class="slider-input" id="hosting-workers-input"
                                                       t-att-min="hosting_config.get('min_workers', 2)"
                                                       t-att-max="hosting_config.get('max_workers', 8)"
                                                       step="1" t-att-value="hosting_config.get('min_workers', 2)"/>
                                                <span>Workers</span>
                                            </div>
                                        </div>
                                        <div class="slider-container">
                                            <input type="range" class="custom-slider" id="hosting-workers-slider"
                                                   t-att-min="hosting_config.get('min_workers', 2)"
                                                   t-att-max="hosting_config.get('max_workers', 8)"
                                                   step="1" t-att-value="hosting_config.get('min_workers', 2)"/>
                                            <div class="slider-ticks" id="hosting-workers-ticks"></div>
                                        </div>
                                    </div>

                                    <div class="slider-group mt-4" id="hosting-storage-slider-group">
                                        <div class="slider-header">
                                            <div class="slider-label">
                                                <i class="fas fa-hdd me-2"></i>Storage
                                            </div>
                                            <div class="slider-value" id="hosting-storage-value">
                                                <input type="number" class="slider-input" id="hosting-storage-input"
                                                       t-att-min="hosting_config.get('min_storage', 5)"
                                                       t-att-max="hosting_config.get('max_storage', 200)"
                                                       step="1" t-att-value="hosting_config.get('min_storage', 5)"/>
                                                <span>GB</span>
                                            </div>
                                        </div>
                                        <div class="slider-container">
                                            <input type="range" class="custom-slider" id="hosting-storage-slider"
                                                   t-att-min="hosting_config.get('min_storage', 5)"
                                                   t-att-max="hosting_config.get('max_storage', 200)"
                                                   step="1" t-att-value="hosting_config.get('min_storage', 5)"/>
                                            <div class="slider-ticks" id="hosting-storage-ticks"></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Right: Price Summary -->
                                <div class="col-lg-5">
                                    <div class="custom-price-card">
                                        <h5 class="mb-3">Hosting Plan</h5>
                                        <div class="price-breakdown">
                                            <div class="breakdown-row">
                                                <span class="breakdown-label">
                                                    <i class="fas fa-cogs me-2"></i>
                                                    <span id="hosting-summary-workers">2</span> Workers
                                                </span>
                                                <span class="breakdown-value" id="hosting-summary-workers-cost">$0.00</span>
                                            </div>
                                            <div class="breakdown-row">
                                                <span class="breakdown-label">
                                                    <i class="fas fa-hdd me-2"></i>
                                                    <span id="hosting-summary-storage">5</span> GB Storage
                                                </span>
                                                <span class="breakdown-value" id="hosting-summary-storage-cost">$0.00</span>
                                            </div>
                                            <div class="breakdown-row">
                                                <span class="breakdown-label">
                                                    <i class="fas fa-shield-alt me-2"></i>Backups
                                                </span>
                                                <span class="breakdown-value">
                                                    <span id="hosting-summary-backups" style="font-weight:700;"><t t-esc="hosting_config.get('min_backups', 3)"/></span>
                                                </span>
                                            </div>
                                            <div class="breakdown-divider"></div>
                                            <div id="hosting-summary-monthly-display">
                                                <div class="breakdown-total">
                                                    <span>Monthly Total</span>
                                                    <span class="total-amount" id="hosting-summary-monthly-total">$0.00</span>
                                                </div>
                                            </div>
                                            <div id="hosting-summary-yearly-display" style="display:none;">
                                                <div class="breakdown-total">
                                                    <span>Yearly Total</span>
                                                    <span class="total-amount" id="hosting-summary-yearly-total">$0.00</span>
                                                </div>
                                                <div class="mt-2 p-2" style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);border-radius:8px;">
                                                    <div style="font-size:0.85rem;font-weight:600;color:var(--success);">
                                                        <i class="fas fa-piggy-bank me-1"></i>
                                                        You save <span id="hosting-summary-yearly-savings">$0</span> per year
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <a id="hosting-cta"
                                           class="btn btn-primary btn-lg w-100 mt-3"
                                           href="/hosting/configure">
                                            <i class="fas fa-rocket me-2"></i>Get Started
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Hidden config data for JavaScript -->
                    <div id="hosting-plan-config" style="display:none;"
                         t-att-data-worker-price="hosting_config.get('worker_price', 10)"
                         t-att-data-storage-price="hosting_config.get('storage_price_per_gb', 0.3)"
                         t-att-data-min-workers="hosting_config.get('min_workers', 2)"
                         t-att-data-max-workers="hosting_config.get('max_workers', 8)"
                         t-att-data-min-storage="hosting_config.get('min_storage', 5)"
                         t-att-data-max-storage="hosting_config.get('max_storage', 200)"
                         t-att-data-yearly-discount-pct="hosting_config.get('yearly_discount_pct', 20)"
                         t-att-data-currency="hosting_config.get('currency', 'USD')"
                         t-att-data-min-backups="hosting_config.get('min_backups', 3)"
                         t-att-data-max-backups="hosting_config.get('max_backups', 14)">
                    </div>
                </div>
            </section>
        </t>
    </template>

    <!-- ============================================================
         Hosting Configure Form  —  /hosting/configure
         ============================================================ -->

    <template id="hosting_configure_form" name="Configure Hosting Instance">
        <t t-call="saas_website.cloudodoo_layout">
            <section class="py-6" style="padding-top:120px;">
                <div class="container">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/hosting">Hosting</a></li>
                            <li class="breadcrumb-item active">Configure</li>
                        </ol>
                    </nav>

                    <h1 class="mb-4">Configure Your Hosting Instance</h1>

                    <t t-if="error">
                        <div class="alert-banner alert-danger mb-4">
                            <i class="fas fa-exclamation-circle"></i>
                            <div t-esc="error"/>
                        </div>
                    </t>

                    <form action="/hosting/order" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="workers" t-att-value="workers"/>
                        <input type="hidden" name="storage" t-att-value="storage"/>
                        <input type="hidden" name="billing_period" t-att-value="billing_period"/>
                        <t t-if="form_values.get('is_trial') == '1'">
                            <input type="hidden" name="is_trial" value="1"/>
                        </t>

                        <div class="row g-4">
                            <!-- Left: Form -->
                            <div class="col-lg-7">
                                <div class="info-card">
                                    <h5 class="mb-4">Instance Details</h5>

                                    <!-- Subdomain -->
                                    <div class="mb-3">
                                        <label class="form-label">Subdomain</label>
                                        <div class="input-group">
                                            <span class="input-group-text">https://</span>
                                            <input type="text" name="subdomain" id="subdomain-input"
                                                   class="form-control" placeholder="my-company"
                                                   t-att-value="form_values.get('subdomain', '')"
                                                   autocomplete="off" required="required"/>
                                            <select name="domain_id" class="form-select" style="max-width:40%;"
                                                    id="domain-select">
                                                <t t-foreach="domains" t-as="dom">
                                                    <option t-att-value="dom.id"
                                                            t-att-selected="dom.id == int(form_values.get('domain_id', 0))">
                                                        .<t t-esc="dom.name"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>
                                        <div id="subdomain-feedback" class="mt-1" style="font-size:0.85rem;"></div>
                                    </div>

                                    <!-- Odoo Version -->
                                    <div class="mb-3">
                                        <label class="form-label">Odoo Version</label>
                                        <select name="odoo_version_id" class="form-select" required="required">
                                            <option value="">Select version...</option>
                                            <t t-foreach="versions" t-as="ver">
                                                <option t-att-value="ver.id"
                                                        t-att-selected="ver.id == odoo_version_id">
                                                    Odoo <t t-esc="ver.name"/>
                                                </option>
                                            </t>
                                        </select>
                                    </div>

                                    <!-- Daily backup add-on (paid only — hidden for trials) -->
                                    <t t-if="form_values.get('is_trial') != '1' and config.get('daily_backup_price', 0) &gt; 0">
                                        <div class="mb-3 p-3"
                                             style="background:rgba(16,185,129,0.05);
                                                    border:1px solid rgba(16,185,129,0.25);
                                                    border-radius:10px;">
                                            <div class="form-check d-flex align-items-start gap-2">
                                                <input type="checkbox" name="daily_backup" value="1"
                                                       class="form-check-input mt-1"
                                                       id="daily-backup-toggle"
                                                       t-att-data-price="config.get('daily_backup_price', 0)"
                                                       t-att-data-yearly-discount="config.get('yearly_discount_pct', 20)"
                                                       t-att-checked="daily_backup or None"/>
                                                <label class="form-check-label" for="daily-backup-toggle">
                                                    <span class="fw-semibold">
                                                        <i class="fas fa-shield-alt me-1"></i>Add daily backups
                                                        — <t t-esc="'${:,.2f}'.format(config.get('daily_backup_price', 0))"/>/mo
                                                    </span>
                                                    <div class="small mt-1" style="color:var(--co-text-muted,#71717A);">
                                                        Every database on this instance is dumped daily to encrypted
                                                        cloud storage. The last 7 days per database are kept; older
                                                        backups roll off automatically. Restore any backup with one
                                                        click from your portal.
                                                    </div>
                                                </label>
                                            </div>
                                        </div>
                                    </t>

                                    <hr style="border-color:var(--border-color,#27272A);"/>
                                    <h5 class="mb-3">
                                        <i class="fas fa-code-branch me-2"></i>Your Project
                                        <span class="text-muted small">(optional)</span>
                                    </h5>
                                    <p class="text-muted small mb-3">
                                        Leave empty to start with a clean Odoo instance. You can connect your repository later.
                                    </p>

                                    <!-- Git Repo URL -->
                                    <div class="mb-3">
                                        <label class="form-label">Repository URL</label>
                                        <input type="url" name="repo_url" class="form-control"
                                               placeholder="https://github.com/user/my-odoo-project.git"
                                               t-att-value="form_values.get('repo_url', '')"/>
                                        <div class="form-text text-muted">The URL of your Odoo project repository.</div>
                                    </div>

                                    <!-- Branch -->
                                    <div class="mb-3">
                                        <label class="form-label">Branch</label>
                                        <input type="text" name="repo_branch" class="form-control"
                                               placeholder="main"
                                               t-att-value="form_values.get('repo_branch', 'main')"/>
                                    </div>

                                    <!-- Git Token -->
                                    <div class="mb-3">
                                        <label class="form-label">Access Token</label>
                                        <input type="password" name="git_token" class="form-control"
                                               placeholder="ghp_xxxxxxxxxxxx"
                                               t-att-value="form_values.get('git_token', '')"/>
                                        <div class="form-text text-muted">
                                            Required for private repositories and to enable auto-updates when you push changes.
                                        </div>
                                    </div>

                                </div>
                            </div>

                            <!-- Right: Order Summary -->
                            <div class="col-lg-5">
                                <div class="custom-price-card">
                                    <h5 class="mb-3">Order Summary</h5>

                                    <div class="d-flex align-items-center gap-3 mb-3 pb-3"
                                         style="border-bottom:1px solid var(--border-color,#27272A);">
                                        <div class="service-icon" style="width:48px;height:48px;">
                                            <i class="fas fa-server"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold">Cloud Hosting</div>
                                            <t t-if="form_values.get('is_trial') == '1'">
                                                <span class="badge bg-success">Free Trial</span>
                                            </t>
                                            <t t-else="">
                                                <span class="badge bg-primary"><t t-esc="billing_period"/></span>
                                            </t>
                                        </div>
                                    </div>

                                    <t t-if="form_values.get('is_trial') == '1'">
                                        <!-- Trial: show resources only, no prices -->
                                        <div class="mb-3">
                                            <div class="d-flex justify-content-between mb-2" style="color:var(--co-text-secondary,#A1A1AA);font-size:0.9rem;">
                                                <span><i class="fas fa-cogs me-2"></i>Workers</span>
                                                <span class="fw-semibold" style="color:var(--co-text-primary,#FAFAFA);"><t t-esc="workers"/></span>
                                            </div>
                                            <div class="d-flex justify-content-between mb-2" style="color:var(--co-text-secondary,#A1A1AA);font-size:0.9rem;">
                                                <span><i class="fas fa-hdd me-2"></i>Storage</span>
                                                <span class="fw-semibold" style="color:var(--co-text-primary,#FAFAFA);"><t t-esc="storage"/>GB</span>
                                            </div>
                                        </div>
                                        <div class="p-3 text-center" style="background:rgba(16,185,129,0.06);border:1px solid rgba(16,185,129,0.15);border-radius:10px;">
                                            <div style="color:var(--success);font-weight:600;font-size:1.5rem;">FREE</div>
                                            <div class="small" style="color:var(--co-text-muted,#71717A);">
                                                for <t t-esc="config.get('trial_days', 14)"/> days
                                            </div>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <!-- Paid: show full price breakdown -->
                                        <div class="price-breakdown">
                                            <div class="breakdown-row">
                                                <span class="breakdown-label"><i class="fas fa-cogs me-2"></i><t t-esc="workers"/> Workers</span>
                                                <span class="breakdown-value"><t t-esc="'${:,.2f}'.format(workers_cost)"/>/mo</span>
                                            </div>
                                            <div class="breakdown-row">
                                                <span class="breakdown-label"><i class="fas fa-hdd me-2"></i><t t-esc="storage"/>GB Storage</span>
                                                <span class="breakdown-value"><t t-esc="'${:,.2f}'.format(storage_cost)"/>/mo</span>
                                            </div>
                                            <div class="breakdown-row"
                                                 id="backup-cost-row"
                                                 t-att-style="'' if daily_backup else 'display:none;'">
                                                <span class="breakdown-label"><i class="fas fa-shield-alt me-2"></i>Daily Backups</span>
                                                <span class="breakdown-value" id="backup-cost-value">
                                                    <t t-esc="'${:,.2f}'.format(backup_cost)"/>/mo
                                                </span>
                                            </div>
                                            <div class="breakdown-row">
                                                <span class="breakdown-label"><i class="fas fa-archive me-2"></i>Plan Backups</span>
                                                <span class="breakdown-value" style="font-weight:700;"><t t-esc="backup_count"/></span>
                                            </div>
                                            <div class="breakdown-divider"></div>
                                            <div class="breakdown-total">
                                                <span>
                                                    <t t-if="billing_period == 'yearly'">Yearly Total</t>
                                                    <t t-else="">Monthly Total</t>
                                                </span>
                                                <span class="total-amount" id="hosting-total-amount"
                                                      t-att-data-base-monthly="monthly_total - backup_cost"
                                                      t-att-data-billing="billing_period">
                                                    <t t-if="billing_period == 'yearly'">
                                                        <t t-esc="'${:,.2f}'.format(yearly_total)"/>
                                                    </t>
                                                    <t t-else="">
                                                        <t t-esc="'${:,.2f}'.format(monthly_total)"/>
                                                    </t>
                                                </span>
                                            </div>
                                        </div>
                                        <!-- Live update when the daily-backup checkbox toggles, so
                                             the customer sees the new total without a page reload. -->
                                        <script>
                                            (function(){
                                                var cb = document.getElementById('daily-backup-toggle');
                                                if (!cb) return;
                                                var row = document.getElementById('backup-cost-row');
                                                var costEl = document.getElementById('backup-cost-value');
                                                var totalEl = document.getElementById('hosting-total-amount');
                                                if (!totalEl) return;
                                                var baseMonthly = parseFloat(totalEl.dataset.baseMonthly) || 0;
                                                var billing = totalEl.dataset.billing;
                                                var price = parseFloat(cb.dataset.price) || 0;
                                                var yd = (parseFloat(cb.dataset.yearlyDiscount) || 0) / 100;
                                                function fmt(n) { return '$' + n.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2}); }
                                                function refresh() {
                                                    var addon = cb.checked ? price : 0;
                                                    var monthly = baseMonthly + addon;
                                                    if (row) row.style.display = cb.checked ? '' : 'none';
                                                    if (costEl) costEl.textContent = fmt(addon) + '/mo';
                                                    totalEl.textContent = billing === 'yearly'
                                                        ? fmt(monthly * 12 * (1 - yd))
                                                        : fmt(monthly);
                                                }
                                                cb.addEventListener('change', refresh);
                                            })();
                                        </script>
                                    </t>

                                    <t t-if="form_values.get('is_trial') == '1'">
                                        <button type="submit" id="submit-btn" class="btn btn-success btn-lg w-100 mt-3"
                                                data-loading-text="Starting trial...">
                                            <i class="fas fa-rocket me-2"></i>Start Free Trial
                                        </button>
                                        <p class="text-muted small mt-2 mb-0 text-center">
                                            <i class="fas fa-gift me-1"></i>No credit card required. <t t-esc="config.get('trial_days', 14)"/> days free.
                                        </p>
                                    </t>
                                    <t t-else="">
                                        <button type="submit" id="submit-btn" class="btn btn-primary btn-lg w-100 mt-3"
                                                data-loading-text="Processing order...">
                                            <i class="fas fa-credit-card me-2"></i>Continue to Payment
                                        </button>
                                        <p class="text-muted small mt-2 mb-0 text-center">
                                            <i class="fas fa-lock me-1"></i>Secure checkout. Cancel anytime.
                                        </p>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </form>

                    <div class="text-center mt-4">
                        <a href="/hosting" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Back to Hosting
                        </a>
                    </div>
                </div>
            </section>
        </t>
    </template>

    <!-- ============================================================
         Live Logs Page  —  /my/instances/<id>/logs
         ============================================================ -->

    <template id="portal_instance_logs" name="Instance Logs">
        <t t-call="saas_website.cloudodoo_layout">
            <section class="py-6" style="padding-top:120px;">
                <div class="container">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/my/instances">My Instances</a></li>
                            <li class="breadcrumb-item">
                                <a t-attf-href="/my/instances/#{instance.id}"
                                   t-esc="instance.subdomain or instance.name"/>
                            </li>
                            <li class="breadcrumb-item active">Logs</li>
                        </ol>
                    </nav>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h1 class="h3 mb-0">
                            <i class="fas fa-terminal me-2"></i>Live Logs
                        </h1>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-secondary" id="logs-pause-btn">
                                <i class="fas fa-pause me-1"></i>Pause
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" id="logs-clear-btn">
                                <i class="fas fa-trash me-1"></i>Clear
                            </button>
                        </div>
                    </div>

                    <div id="log-output" class="log-viewer"
                         t-att-data-instance-id="instance.id"
                         t-att-data-stream-url="stream_url">
                        <div class="log-line text-muted">Connecting to log stream...</div>
                    </div>

                    <div class="mt-3">
                        <a t-attf-href="/my/instances/#{instance.id}" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Back to Instance
                        </a>
                    </div>
                </div>
            </section>
        </t>
    </template>

</odoo>
