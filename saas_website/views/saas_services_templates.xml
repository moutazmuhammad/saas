<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  1. Services Catalog Page  –  /services                       -->
    <!-- ============================================================ -->

    <template id="services_page" name="SaaS Services Catalog">
        <t t-call="website.layout">
            <t t-set="additional_title">Services</t>

            <div class="container py-5">
                <div class="text-center mb-5">
                    <h1 class="display-5 fw-bold">Our Services</h1>
                    <p class="lead text-muted">
                        Choose the solution that fits your business.
                        Each service comes with flexible plans and a free trial.
                    </p>
                </div>

                <div class="row justify-content-center g-4">
                    <t t-foreach="products" t-as="product">
                        <div class="col-lg-4 col-md-6">
                            <div class="card h-100 shadow-sm border-0 text-center
                                        saas-service-card">
                                <div class="card-body d-flex flex-column px-4 py-5">
                                    <!-- Icon -->
                                    <div class="mb-3">
                                        <t t-if="product.image">
                                            <img t-att-src="'data:image/png;base64,%s' % product.image.decode()"
                                                 class="rounded"
                                                 style="max-height:80px;"
                                                 t-att-alt="product.name"/>
                                        </t>
                                        <t t-else="">
                                            <i t-att-class="'%s fa-3x text-primary' % (product.icon or 'fa fa-cogs')"/>
                                        </t>
                                    </div>

                                    <!-- Name & Subtitle -->
                                    <h4 class="fw-bold mb-2" t-field="product.name"/>
                                    <p t-if="product.subtitle"
                                       class="text-muted mb-3" t-field="product.subtitle"/>

                                    <!-- Feature Bullets -->
                                    <ul t-if="product.feature_line_ids"
                                        class="list-unstyled text-start mb-4 flex-grow-1">
                                        <t t-foreach="product.feature_line_ids" t-as="feat">
                                            <li class="mb-2">
                                                <i t-att-class="'%s text-success me-2' % (feat.icon or 'fa fa-check')"/>
                                                <t t-out="feat.name"/>
                                            </li>
                                        </t>
                                    </ul>

                                    <!-- Plans count hint -->
                                    <p class="text-muted small mb-3">
                                        <t t-out="product.plan_count"/> plan(s) available
                                    </p>

                                    <!-- CTA -->
                                    <a t-attf-href="/services/#{product.id}"
                                       class="btn btn-primary btn-lg w-100 mt-auto">
                                        View Plans
                                    </a>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <t t-if="not products">
                    <div class="text-center text-muted py-5">
                        <p class="lead">
                            No services available at the moment. Please check back later.
                        </p>
                    </div>
                </t>
            </div>

        </t>
    </template>

    <!-- ============================================================ -->
    <!--  2. Service Plans Page  –  /services/<id>                     -->
    <!-- ============================================================ -->

    <template id="service_plans_page" name="SaaS Service Plans">
        <t t-call="website.layout">
            <t t-set="additional_title" t-value="product.name"/>

            <div class="container py-5">
                <!-- Back link -->
                <a href="/services" class="btn btn-outline-secondary btn-sm mb-4">
                    <i class="fa fa-arrow-left me-1"/> All Services
                </a>

                <!-- Service Header -->
                <div class="text-center mb-5">
                    <div class="mb-3">
                        <t t-if="product.image">
                            <img t-att-src="'data:image/png;base64,%s' % product.image.decode()"
                                 class="rounded"
                                 style="max-height:80px;"
                                 t-att-alt="product.name"/>
                        </t>
                        <t t-else="">
                            <i t-att-class="'%s fa-3x text-primary' % (product.icon or 'fa fa-cogs')"/>
                        </t>
                    </div>
                    <h1 class="display-5 fw-bold" t-field="product.name"/>
                    <p t-if="product.subtitle" class="lead text-muted"
                       t-field="product.subtitle"/>
                </div>

                <!-- Description (if provided) -->
                <div t-if="product.description" class="row justify-content-center mb-5">
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body" t-field="product.description"/>
                        </div>
                    </div>
                </div>

                <!-- Monthly / Yearly Toggle -->
                <t t-set="has_yearly" t-value="any(p.yearly_price for p in plans)"/>
                <div t-if="has_yearly" class="text-center mb-4">
                    <div class="btn-group" role="group" id="billing-toggle">
                        <button type="button"
                                class="btn btn-primary active"
                                onclick="document.querySelectorAll('.price-monthly').forEach(e => e.style.display='');
                                         document.querySelectorAll('.price-yearly').forEach(e => e.style.display='none');
                                         this.classList.add('active','btn-primary'); this.classList.remove('btn-outline-primary');
                                         this.nextElementSibling.classList.remove('active','btn-primary'); this.nextElementSibling.classList.add('btn-outline-primary');">
                            Monthly
                        </button>
                        <button type="button"
                                class="btn btn-outline-primary"
                                onclick="document.querySelectorAll('.price-monthly').forEach(e => e.style.display='none');
                                         document.querySelectorAll('.price-yearly').forEach(e => e.style.display='');
                                         this.classList.add('active','btn-primary'); this.classList.remove('btn-outline-primary');
                                         this.previousElementSibling.classList.remove('active','btn-primary'); this.previousElementSibling.classList.add('btn-outline-primary');">
                            Yearly
                            <span class="badge bg-success ms-1">Save more</span>
                        </button>
                    </div>
                </div>

                <!-- Plans Grid -->
                <div class="row justify-content-center g-4">
                    <t t-foreach="plans" t-as="plan">
                        <div class="col-lg-4 col-md-6">
                            <div class="card h-100 shadow-sm border-0">
                                <div class="card-header bg-primary text-white text-center py-3">
                                    <h4 class="mb-0 fw-bold" t-field="plan.name"/>
                                </div>
                                <div class="card-body d-flex flex-column px-4 py-4">
                                    <!-- Monthly Price -->
                                    <div class="text-center mb-4 price-monthly">
                                        <span class="display-6 fw-bold">
                                            <t t-if="plan.currency_id" t-out="plan.currency_id.symbol"/>
                                            <t t-out="int(plan.price) if plan.price == int(plan.price) else '%.2f' % plan.price"/>
                                        </span>
                                        <span class="text-muted">/ mo</span>
                                    </div>

                                    <!-- Yearly Price (hidden by default) -->
                                    <div class="text-center mb-4 price-yearly" style="display: none;">
                                        <t t-if="plan.yearly_price">
                                            <span class="display-6 fw-bold">
                                                <t t-if="plan.currency_id" t-out="plan.currency_id.symbol"/>
                                                <t t-out="int(plan.yearly_price) if plan.yearly_price == int(plan.yearly_price) else '%.2f' % plan.yearly_price"/>
                                            </span>
                                            <span class="text-muted">/ yr</span>
                                            <div class="mt-1">
                                                <span class="text-muted text-decoration-line-through" style="font-size: 0.9rem;">
                                                    <t t-if="plan.currency_id" t-out="plan.currency_id.symbol"/><t t-out="int(plan.price * 12)"/>
                                                </span>
                                                <span t-if="plan.yearly_discount_pct" class="badge bg-success ms-1">
                                                    Save <t t-out="int(plan.yearly_discount_pct)"/>%
                                                </span>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <span class="display-6 fw-bold">
                                                <t t-if="plan.currency_id" t-out="plan.currency_id.symbol"/>
                                                <t t-out="int(plan.price * 12)"/>
                                            </span>
                                            <span class="text-muted">/ yr</span>
                                        </t>
                                    </div>

                                    <!-- Features -->
                                    <ul class="list-unstyled mb-4 flex-grow-1">
                                        <li class="mb-2">
                                            <i class="fa fa-microchip text-primary me-2"/>
                                            <strong t-out="plan.cpu_limit"/> CPU
                                            <t t-if="plan.cpu_limit == 1"> Core</t>
                                            <t t-else=""> Cores</t>
                                        </li>
                                        <li class="mb-2">
                                            <i class="fa fa-memory text-primary me-2"/>
                                            <t t-out="plan.ram_limit.upper() if plan.ram_limit else 'N/A'"/> RAM
                                        </li>
                                        <li class="mb-2">
                                            <i class="fa fa-hdd-o text-primary me-2"/>
                                            <t t-out="int(plan.storage_limit)"/> GB Storage
                                        </li>
                                        <li class="mb-2">
                                            <i class="fa fa-cloud-download text-primary me-2"/>
                                            <t t-out="plan.max_backups"/> Daily Backups
                                        </li>
                                        <li t-if="plan.recommended_users" class="mb-2">
                                            <i class="fa fa-users text-primary me-2"/>
                                            Recommended for up to <t t-out="plan.recommended_users"/> users
                                        </li>
                                    </ul>

                                    <!-- CTA: Get Started (paid plan) -->
                                    <a t-if="request.env.user._is_public()"
                                       t-attf-href="/services/register?product_id=#{product.id}&amp;plan_id=#{plan.id}"
                                       class="btn btn-primary btn-lg w-100 mt-auto">
                                        Get Started
                                    </a>
                                    <a t-else=""
                                       t-attf-href="/services/#{product.id}/plans/#{plan.id}/configure"
                                       class="btn btn-primary btn-lg w-100 mt-auto">
                                        Get Started
                                    </a>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <!-- Free Trial Banner -->
                <div t-if="trial_available and trial_plan"
                     class="row justify-content-center mt-4">
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm bg-light">
                            <div class="card-body d-flex align-items-center justify-content-between py-4 px-4">
                                <div>
                                    <h5 class="mb-1">
                                        <i class="fa fa-gift text-success me-2"/>Not ready to commit?
                                    </h5>
                                    <p class="text-muted mb-0">
                                        Try it free for <strong><t t-out="trial_days"/> days</strong> — no credit card required.
                                    </p>
                                </div>
                                <a t-if="request.env.user._is_public()"
                                   t-attf-href="/services/register?product_id=#{product.id}&amp;plan_id=#{trial_plan.id}&amp;is_trial=1"
                                   class="btn btn-success btn-lg ms-3 flex-shrink-0">
                                    <i class="fa fa-gift me-1"/>Start Free Trial
                                </a>
                                <a t-else=""
                                   t-attf-href="/services/#{product.id}/plans/#{trial_plan.id}/configure?trial=1"
                                   class="btn btn-success btn-lg ms-3 flex-shrink-0">
                                    <i class="fa fa-gift me-1"/>Start Free Trial
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <t t-if="not plans and not (trial_available and trial_plan)">
                    <div class="text-center text-muted py-5">
                        <p class="lead">
                            No plans available for this service yet. Please check back later.
                        </p>
                    </div>
                </t>
            </div>

        </t>
    </template>

    <!-- ============================================================ -->
    <!--  3. Configure Instance  –  /services/<id>/plans/<pid>/configure -->
    <!-- ============================================================ -->

    <template id="service_configure_form" name="Configure Your Instance">
        <t t-call="website.layout">
            <t t-set="additional_title">Configure Instance</t>

            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8">

                        <!-- Breadcrumb-style navigation -->
                        <nav aria-label="breadcrumb" class="mb-4">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item">
                                    <a href="/services">Services</a>
                                </li>
                                <li class="breadcrumb-item">
                                    <a t-attf-href="/services/#{product.id}">
                                        <t t-out="product.name"/>
                                    </a>
                                </li>
                                <li class="breadcrumb-item active" aria-current="page">
                                    Configure
                                </li>
                            </ol>
                        </nav>

                        <!-- Service + Plan Summary -->
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body d-flex align-items-center">
                                <div class="me-3">
                                    <t t-if="product.image">
                                        <img t-att-src="'data:image/png;base64,%s' % product.image.decode()"
                                             class="rounded"
                                             style="max-height:40px;"
                                             t-att-alt="product.name"/>
                                    </t>
                                    <t t-else="">
                                        <i t-att-class="'%s fa-2x text-primary' % (product.icon or 'fa fa-cogs')"/>
                                    </t>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mb-1">
                                        <t t-out="product.name"/>
                                        <span class="text-muted mx-1">|</span>
                                        <strong t-field="plan.name"/>
                                    </h5>
                                    <span class="text-muted">
                                        <t t-if="plan.currency_id" t-out="plan.currency_id.symbol"/>
                                        <t t-out="'%.2f' % plan.price"/> / mo
                                        <t t-if="plan.yearly_price">
                                            <span class="mx-1">|</span>
                                            <t t-if="plan.currency_id" t-out="plan.currency_id.symbol"/>
                                            <t t-out="'%.2f' % plan.yearly_price"/> / yr
                                        </t>
                                        <span class="mx-2">|</span>
                                        <t t-out="plan.cpu_limit"/> CPU,
                                        <t t-out="plan.ram_limit"/> RAM,
                                        <t t-out="int(plan.storage_limit)"/> GB Storage
                                    </span>
                                </div>
                                <a t-attf-href="/services/#{product.id}"
                                   class="btn btn-outline-secondary btn-sm">
                                    Change Plan
                                </a>
                            </div>
                        </div>

                        <!-- Trial Badge -->
                        <div t-if="is_trial" class="alert alert-success d-flex align-items-center mb-4">
                            <i class="fa fa-gift fa-2x me-3"/>
                            <div>
                                <strong>Free Trial</strong> — You will get a fully
                                functional instance at no cost. No credit card required.
                            </div>
                        </div>

                        <!-- Error message -->
                        <div t-if="error" class="alert alert-danger" role="alert">
                            <t t-out="error"/>
                        </div>

                        <!-- Configuration Form -->
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white">
                                <h4 class="mb-0">Configure Your Instance</h4>
                            </div>
                            <div class="card-body">
                                <form action="/services/order" method="POST">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="product_id"
                                           t-att-value="product.id"/>
                                    <input type="hidden" name="plan_id"
                                           t-att-value="plan.id"/>
                                    <input t-if="is_trial" type="hidden"
                                           name="is_trial" value="1"/>

                                    <!-- Subdomain -->
                                    <div class="mb-4">
                                        <label for="subdomain" class="form-label fw-bold">
                                            Subdomain
                                        </label>
                                        <div class="input-group">
                                            <input type="text" name="subdomain" id="subdomain"
                                                   class="form-control form-control-lg"
                                                   placeholder="your-company"
                                                   required="required"
                                                   pattern="[a-z0-9]([a-z0-9\-]{0,61}[a-z0-9])?"
                                                   t-att-value="form_values.get('subdomain', '')"
                                                   autocomplete="off"/>
                                            <span class="input-group-text" id="domain-suffix">
                                                .<t t-if="domains" t-out="domains[0].name"/>
                                            </span>
                                        </div>
                                        <div id="subdomain-feedback" class="form-text"></div>
                                        <small class="text-muted">
                                            Lowercase letters, digits, and hyphens only.
                                        </small>
                                    </div>

                                    <!-- Base Domain -->
                                    <div class="mb-4">
                                        <label for="domain_id" class="form-label fw-bold">
                                            Base Domain
                                        </label>
                                        <select name="domain_id" id="domain_id"
                                                class="form-select" required="required">
                                            <t t-foreach="domains" t-as="domain">
                                                <option t-att-value="domain.id"
                                                        t-att-selected="str(domain.id) == str(form_values.get('domain_id', domains[0].id if domains else ''))">
                                                    <t t-out="domain.name"/>
                                                </option>
                                            </t>
                                        </select>
                                    </div>

                                    <!-- Submit -->
                                    <button t-if="is_trial" type="submit"
                                            class="btn btn-success btn-lg w-100">
                                        <i class="fa fa-gift me-2"/>Start Free Trial
                                    </button>
                                    <button t-else="" type="submit"
                                            class="btn btn-primary btn-lg w-100">
                                        <i class="fa fa-lock me-2"/>Continue to Payment
                                    </button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </t>
    </template>

</odoo>
