<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Services Catalog Page  —  /services
         ============================================================ -->

    <template id="services_page" name="SaaS Services">
        <t t-call="saas_website.cloudodoo_layout">
            <section class="py-6" style="padding-top:120px;">
                <div class="container">
                    <div class="text-center mb-5">
                        <h1 class="display-4 fw-bold mb-3">Cloud Business Solutions</h1>
                        <p class="lead text-muted mx-auto" style="max-width:600px;">
                            Choose from our range of fully managed Odoo applications.
                            Deploy in minutes, scale as you grow.
                        </p>
                    </div>

                    <!-- Services Grid -->
                    <div class="row g-4">
                        <t t-foreach="products" t-as="product">
                            <div class="col-md-6 col-lg-4">
                                <div class="service-card">
                                    <div class="service-icon">
                                        <t t-if="product.icon">
                                            <i t-att-class="product.icon"/>
                                        </t>
                                        <t t-else="">
                                            <i class="fas fa-cubes"/>
                                        </t>
                                    </div>
                                    <h4 t-esc="product.name"/>
                                    <p class="service-subtitle" t-if="product.subtitle" t-esc="product.subtitle"/>
                                    <t t-if="product.description">
                                        <p class="text-muted small" t-esc="product.description"/>
                                    </t>
                                    <p class="plan-count">
                                        <i class="fas fa-layer-group me-1"></i>
                                        <t t-esc="len(product.plan_ids.filtered(lambda p: not p.is_trial_plan))"/> plans available
                                    </p>
                                    <a t-attf-href="/services/#{product.id}" class="btn btn-primary w-100">
                                        View Plans
                                    </a>
                                </div>
                            </div>
                        </t>

                        <!-- Empty state -->
                        <t t-if="not products">
                            <div class="col-12">
                                <div class="empty-state">
                                    <div class="empty-state-icon">
                                        <i class="fas fa-box-open"></i>
                                    </div>
                                    <h5>No services available</h5>
                                    <p>Please check back soon for available services.</p>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </section>

            <!-- Features Banner -->
            <section class="py-5 bg-dark-gradient">
                <div class="container">
                    <div class="row g-4 text-center">
                        <div class="col-md-3">
                            <div class="d-flex flex-column align-items-center">
                                <div class="feature-icon mb-3"><i class="fas fa-rocket"></i></div>
                                <h6>Instant Setup</h6>
                                <p class="text-muted small mb-0">Deploy in under 5 minutes</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="d-flex flex-column align-items-center">
                                <div class="feature-icon mb-3"><i class="fas fa-shield-alt"></i></div>
                                <h6>Fully Managed</h6>
                                <p class="text-muted small mb-0">Backups &amp; security included</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="d-flex flex-column align-items-center">
                                <div class="feature-icon mb-3"><i class="fas fa-expand-arrows-alt"></i></div>
                                <h6>Scalable</h6>
                                <p class="text-muted small mb-0">Upgrade anytime, zero downtime</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="d-flex flex-column align-items-center">
                                <div class="feature-icon mb-3"><i class="fas fa-headset"></i></div>
                                <h6>24/7 Support</h6>
                                <p class="text-muted small mb-0">Expert help when you need it</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </t>
    </template>

    <!-- ============================================================
         Service Plans Page  —  /services/<id>
         ============================================================ -->

    <template id="service_plans_page" name="SaaS Service Plans">
        <t t-call="saas_website.cloudodoo_layout">
            <section class="py-6" style="padding-top:120px;">
                <div class="container">
                    <!-- Breadcrumb -->
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/services">Services</a></li>
                            <li class="breadcrumb-item active" t-esc="product.name"/>
                        </ol>
                    </nav>

                    <!-- Service Header -->
                    <div class="mb-5">
                        <div class="d-flex align-items-start gap-4">
                            <div class="service-icon" style="width:80px;height:80px;font-size:2rem;">
                                <t t-if="product.icon"><i t-att-class="product.icon"/></t>
                                <t t-else=""><i class="fas fa-cubes"/></t>
                            </div>
                            <div>
                                <h1 class="mb-2" t-esc="product.name"/>
                                <p class="text-muted mb-3" t-if="product.subtitle" t-esc="product.subtitle"/>
                                <p class="mb-0" t-if="product.description" t-esc="product.description"/>
                            </div>
                        </div>
                    </div>

                    <!-- Trial Banner: only show if trial is genuinely available for this user -->
                    <t t-if="trial_plan and trial_available">
                        <div class="trial-banner">
                            <div class="d-md-flex align-items-center justify-content-between">
                                <div class="mb-3 mb-md-0">
                                    <h5 class="mb-1"><i class="fas fa-gift me-2"></i>Start with a Free Trial</h5>
                                    <p class="mb-0 text-muted">
                                        No credit card required. <t t-esc="trial_days"/>-day free trial with
                                        <t t-esc="trial_plan.cpu_limit"/> vCPU,
                                        <t t-esc="trial_plan.ram_limit"/> RAM,
                                        <t t-esc="int(trial_plan.storage_limit)"/>GB storage.
                                    </p>
                                </div>
                                <!-- Public users go to register; logged-in users go to configure -->
                                <t t-if="request.env.user._is_public()">
                                    <a t-attf-href="/services/register?product_id=#{product.id}&amp;plan_id=#{trial_plan.id}&amp;is_trial=1"
                                       class="btn btn-success">
                                        <i class="fas fa-rocket me-2"></i>Start Free Trial
                                    </a>
                                </t>
                                <t t-else="">
                                    <a t-attf-href="/services/#{product.id}/plans/#{trial_plan.id}/configure?trial=1"
                                       class="btn btn-success">
                                        <i class="fas fa-rocket me-2"></i>Start Free Trial
                                    </a>
                                </t>
                            </div>
                        </div>
                    </t>

                    <!-- Billing Toggle -->
                    <div class="text-center mb-4" id="billing-toggle">
                        <div class="billing-toggle">
                            <button class="toggle-btn active" data-billing="monthly">Monthly</button>
                            <button class="toggle-btn" data-billing="yearly">
                                Yearly <span class="yearly-badge">Save up to 20%</span>
                            </button>
                        </div>
                    </div>

                    <!-- Plans Grid -->
                    <div class="row g-4">
                        <t t-foreach="plans" t-as="plan">
                            <div class="col-md-6 col-lg-4">
                                <div class="plan-card"
                                     t-att-data-monthly-price="plan.price"
                                     t-att-data-yearly-price="plan.yearly_price"
                                     t-att-data-currency="plan.currency_id.name or 'USD'">
                                    <h4 class="plan-name" t-esc="plan.name"/>

                                    <!-- Price display -->
                                    <div class="plan-price">
                                        <span class="plan-original" style="display:none;text-decoration:line-through;color:var(--text-muted);font-size:1rem;margin-right:0.5rem;"></span>
                                        <span class="plan-amount amount" t-esc="'${:,.0f}'.format(plan.price)"/>
                                        <span class="plan-period period">/mo</span>
                                    </div>

                                    <!-- Yearly savings highlight -->
                                    <t t-if="plan.yearly_price and plan.yearly_price > 0 and plan.yearly_discount_pct > 0">
                                        <div class="mb-3 p-2" style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);border-radius:8px;">
                                            <div style="font-size:0.8rem;color:#10B981;font-weight:600;">
                                                <i class="fas fa-tag me-1"></i>
                                                Save <t t-esc="'%.0f' % plan.yearly_discount_pct"/>% with annual billing
                                            </div>
                                            <div style="font-size:0.8rem;color:var(--text-secondary,#A1A1AA);margin-top:2px;">
                                                <t t-esc="'${:,.2f}'.format(plan.yearly_price / 12)"/>/mo billed yearly
                                                <span style="text-decoration:line-through;color:var(--text-muted,#71717A);margin-left:4px;">
                                                    <t t-esc="'${:,.0f}'.format(plan.price)"/>/mo
                                                </span>
                                                — You save <strong style="color:#10B981;"><t t-esc="'${:,.0f}'.format(plan.price * 12 - plan.yearly_price)"/>/yr</strong>
                                            </div>
                                        </div>
                                    </t>

                                    <ul class="plan-specs">
                                        <li><i class="fas fa-microchip"></i><t t-esc="plan.cpu_limit"/> vCPU</li>
                                        <li><i class="fas fa-memory"></i><t t-esc="plan.ram_limit"/> RAM</li>
                                        <li><i class="fas fa-hdd"></i><t t-esc="int(plan.storage_limit)"/>GB Storage</li>
                                        <li><i class="fas fa-shield-alt"></i><t t-esc="plan.max_backups"/> Backups</li>
                                        <li t-if="plan.recommended_users">
                                            <i class="fas fa-users"></i>Up to <t t-esc="plan.recommended_users"/> Users
                                        </li>
                                    </ul>

                                    <a t-attf-href="/services/#{product.id}/plans/#{plan.id}/configure"
                                       class="btn btn-primary w-100"
                                       t-att-data-plan-link="'/services/%s/plans/%s/configure' % (product.id, plan.id)">
                                        Get Started
                                    </a>
                                </div>
                            </div>
                        </t>
                    </div>

                    <!-- Back Link -->
                    <div class="text-center mt-5">
                        <a href="/services" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Back to Services
                        </a>
                    </div>
                </div>
            </section>
        </t>
    </template>

    <!-- ============================================================
         Configure Instance Page  —  /services/<id>/plans/<pid>/configure
         ============================================================ -->

    <template id="service_configure_form" name="Configure Instance">
        <t t-call="saas_website.cloudodoo_layout">
            <section class="py-6" style="padding-top:120px;">
                <div class="container">
                    <!-- Breadcrumb -->
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/services">Services</a></li>
                            <li class="breadcrumb-item">
                                <a t-attf-href="/services/#{product.id}" t-esc="product.name"/>
                            </li>
                            <li class="breadcrumb-item active">Configure</li>
                        </ol>
                    </nav>

                    <div class="row g-4">
                        <!-- Left Column - Configuration Form -->
                        <div class="col-lg-7">
                            <div class="info-card">
                                <!-- Error display -->
                                <t t-if="error">
                                    <div class="alert-banner alert-danger mb-4">
                                        <i class="fas fa-exclamation-circle"></i>
                                        <div t-esc="error"/>
                                    </div>
                                </t>

                                <form action="/services/order" method="post" id="configure-form">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="product_id" t-att-value="product.id"/>
                                    <input type="hidden" name="plan_id" t-att-value="plan.id"/>
                                    <input type="hidden" name="is_trial" t-att-value="'1' if is_trial else '0'"/>

                                    <h4 class="mb-4">Configure Your Instance</h4>

                                    <div class="mb-4">
                                        <label class="form-label">Choose your subdomain</label>
                                        <div class="input-icon">
                                            <i class="fas fa-globe"></i>
                                            <input type="text" class="form-control" id="subdomain-input"
                                                   name="subdomain" placeholder="my-company" autocomplete="off"
                                                   t-att-value="form_values.get('subdomain', '')"/>
                                        </div>
                                        <div id="subdomain-feedback" class="mt-2"></div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label">Select your domain</label>
                                        <select class="form-select" id="domain-select" name="domain_id">
                                            <t t-foreach="domains" t-as="d">
                                                <option t-att-value="d.id"
                                                        t-att-selected="str(d.id) == str(form_values.get('domain_id', ''))"
                                                        t-esc="d.name"/>
                                            </t>
                                        </select>
                                    </div>

                                    <div class="subdomain-preview mb-4">
                                        <i class="fas fa-link me-2"></i>
                                        <span id="url-preview">your-subdomain.<t t-esc="domains[0].name if domains else 'example.com'"/></span>
                                    </div>

                                    <button type="submit" id="submit-btn" disabled=""
                                            t-attf-class="btn #{'btn-success' if is_trial else 'btn-primary'} btn-lg w-100">
                                        <t t-if="is_trial">
                                            <i class="fas fa-rocket me-2"></i>Start Free Trial
                                        </t>
                                        <t t-else="">
                                            <i class="fas fa-credit-card me-2"></i>Continue to Payment
                                        </t>
                                    </button>
                                </form>
                            </div>
                        </div>

                        <!-- Right Column - Order Summary -->
                        <div class="col-lg-5">
                            <div class="order-summary">
                                <h5><i class="fas fa-shopping-cart me-2"></i>Order Summary</h5>

                                <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom" style="border-color:var(--border-color)!important;">
                                    <div class="service-icon" style="width:48px;height:48px;font-size:1.25rem;">
                                        <t t-if="product.icon"><i t-att-class="product.icon"/></t>
                                        <t t-else=""><i class="fas fa-cubes"/></t>
                                    </div>
                                    <div>
                                        <div class="fw-semibold" t-esc="product.name"/>
                                        <div class="text-muted small"><t t-esc="plan.name"/> Plan</div>
                                    </div>
                                </div>

                                <t t-if="is_trial">
                                    <div class="alert-banner alert-success mb-3">
                                        <i class="fas fa-gift"></i>
                                        <div>
                                            <strong>Free Trial</strong>
                                            <p class="small mb-0 mt-1">14 days free, no credit card required</p>
                                        </div>
                                    </div>
                                </t>

                                <div class="summary-item">
                                    <span class="label"><i class="fas fa-microchip me-2"></i>CPU</span>
                                    <span class="value"><t t-esc="plan.cpu_limit"/> vCPU</span>
                                </div>
                                <div class="summary-item">
                                    <span class="label"><i class="fas fa-memory me-2"></i>RAM</span>
                                    <span class="value"><t t-esc="plan.ram_limit"/></span>
                                </div>
                                <div class="summary-item">
                                    <span class="label"><i class="fas fa-hdd me-2"></i>Storage</span>
                                    <span class="value"><t t-esc="int(plan.storage_limit)"/>GB</span>
                                </div>
                                <div class="summary-item">
                                    <span class="label"><i class="fas fa-shield-alt me-2"></i>Backups</span>
                                    <span class="value">
                                        <t t-if="plan.max_backups"><t t-esc="plan.max_backups"/></t>
                                        <t t-else="">Not included</t>
                                    </span>
                                </div>

                                <t t-if="not is_trial">
                                    <div class="summary-total">
                                        <span>Total</span>
                                        <span><t t-esc="'${:,.0f}'.format(plan.price)"/>/mo</span>
                                    </div>

                                    <!-- Yearly savings upsell -->
                                    <t t-if="plan.yearly_price and plan.yearly_price > 0 and plan.yearly_discount_pct > 0">
                                        <div class="mt-3 p-3" style="background:rgba(16,185,129,0.06);border:1px solid rgba(16,185,129,0.15);border-radius:10px;">
                                            <div class="d-flex align-items-center mb-2">
                                                <span style="background:#10B981;color:white;font-size:0.7rem;font-weight:700;padding:0.2rem 0.6rem;border-radius:20px;margin-right:0.5rem;">
                                                    SAVE <t t-esc="'%.0f' % plan.yearly_discount_pct"/>%
                                                </span>
                                                <span style="font-size:0.85rem;font-weight:600;color:#10B981;">Switch to yearly billing</span>
                                            </div>
                                            <div style="font-size:0.8rem;color:var(--text-secondary,#A1A1AA);">
                                                Pay <strong><t t-esc="'${:,.2f}'.format(plan.yearly_price)"/>/yr</strong>
                                                instead of <span style="text-decoration:line-through;"><t t-esc="'${:,.0f}'.format(plan.price * 12)"/>/yr</span>
                                            </div>
                                            <div style="font-size:0.85rem;font-weight:600;color:#10B981;margin-top:4px;">
                                                <i class="fas fa-piggy-bank me-1"></i>
                                                You save <t t-esc="'${:,.0f}'.format(plan.price * 12 - plan.yearly_price)"/> per year
                                            </div>
                                        </div>
                                    </t>
                                </t>

                                <p class="text-muted small mt-3 mb-0">
                                    <i class="fas fa-info-circle me-1"></i>
                                    You can upgrade or downgrade anytime
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </t>
    </template>

</odoo>
