<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  1. Services Catalog Page  –  /services                       -->
    <!-- ============================================================ -->

    <template id="services_page" name="SaaS Services Catalog">
        <t t-call="website.layout">
            <t t-set="additional_title">Services</t>

            <div class="container py-5">
                <div class="text-center mb-5">
                    <h1 class="display-5 fw-bold">Our Services</h1>
                    <p class="lead text-muted">
                        Choose the solution that fits your business.
                        Each service comes with flexible plans and a free trial.
                    </p>
                </div>

                <div class="row justify-content-center g-4">
                    <t t-foreach="products" t-as="product">
                        <div class="col-lg-4 col-md-6">
                            <div class="card h-100 shadow-sm border-0 text-center
                                        saas-service-card">
                                <div class="card-body d-flex flex-column px-4 py-5">
                                    <!-- Icon -->
                                    <div class="mb-3">
                                        <t t-if="product.image">
                                            <img t-att-src="'data:image/png;base64,%s' % product.image.decode()"
                                                 class="rounded"
                                                 style="max-height:80px;"
                                                 t-att-alt="product.name"/>
                                        </t>
                                        <t t-else="">
                                            <i t-att-class="'%s fa-3x text-primary' % (product.icon or 'fa fa-cogs')"/>
                                        </t>
                                    </div>

                                    <!-- Name & Subtitle -->
                                    <h4 class="fw-bold mb-2" t-field="product.name"/>
                                    <p t-if="product.subtitle"
                                       class="text-muted mb-3" t-field="product.subtitle"/>

                                    <!-- Feature Bullets -->
                                    <ul t-if="product.feature_line_ids"
                                        class="list-unstyled text-start mb-4 flex-grow-1">
                                        <t t-foreach="product.feature_line_ids" t-as="feat">
                                            <li class="mb-2">
                                                <i t-att-class="'%s text-success me-2' % (feat.icon or 'fa fa-check')"/>
                                                <t t-out="feat.name"/>
                                            </li>
                                        </t>
                                    </ul>

                                    <!-- Plans count hint -->
                                    <p class="text-muted small mb-3">
                                        <t t-out="product.plan_count"/> plan(s) available
                                    </p>

                                    <!-- CTA -->
                                    <a t-attf-href="/services/#{product.id}"
                                       class="btn btn-primary btn-lg w-100 mt-auto">
                                        View Plans
                                    </a>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <t t-if="not products">
                    <div class="text-center text-muted py-5">
                        <p class="lead">
                            No services available at the moment. Please check back later.
                        </p>
                    </div>
                </t>
            </div>

        </t>
    </template>

    <!-- ============================================================ -->
    <!--  2. Service Plans Page  –  /services/<id>                     -->
    <!-- ============================================================ -->

    <template id="service_plans_page" name="SaaS Service Plans">
        <t t-call="website.layout">
            <t t-set="additional_title" t-value="product.name"/>

            <div class="container py-5">
                <!-- Back link -->
                <a href="/services" class="btn btn-outline-secondary btn-sm mb-4">
                    <i class="fa fa-arrow-left me-1"/> All Services
                </a>

                <!-- Service Header -->
                <div class="text-center mb-5">
                    <div class="mb-3">
                        <t t-if="product.image">
                            <img t-att-src="'data:image/png;base64,%s' % product.image.decode()"
                                 class="rounded"
                                 style="max-height:80px;"
                                 t-att-alt="product.name"/>
                        </t>
                        <t t-else="">
                            <i t-att-class="'%s fa-3x text-primary' % (product.icon or 'fa fa-cogs')"/>
                        </t>
                    </div>
                    <h1 class="display-5 fw-bold" t-field="product.name"/>
                    <p t-if="product.subtitle" class="lead text-muted"
                       t-field="product.subtitle"/>
                </div>

                <!-- Description (if provided) -->
                <div t-if="product.description" class="row justify-content-center mb-5">
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body" t-field="product.description"/>
                        </div>
                    </div>
                </div>

                <!-- Plans Grid -->
                <div class="row justify-content-center g-4">
                    <t t-foreach="plans" t-as="plan">
                        <div class="col-lg-4 col-md-6">
                            <div class="card h-100 shadow-sm border-0">
                                <div class="card-header bg-primary text-white text-center py-3">
                                    <h4 class="mb-0 fw-bold" t-field="plan.name"/>
                                </div>
                                <div class="card-body d-flex flex-column px-4 py-4">
                                    <!-- Price -->
                                    <div class="text-center mb-4">
                                        <span class="display-6 fw-bold">
                                            <t t-if="plan.currency_id">
                                                <t t-out="plan.currency_id.symbol"/>
                                            </t>
                                            <t t-out="int(plan.price) if plan.price == int(plan.price) else '%.2f' % plan.price"/>
                                        </span>
                                        <span class="text-muted">
                                            / <t t-if="plan.billing_period == 'monthly'">mo</t>
                                              <t t-if="plan.billing_period == 'yearly'">yr</t>
                                        </span>
                                    </div>

                                    <!-- Features -->
                                    <ul class="list-unstyled mb-4 flex-grow-1">
                                        <li class="mb-2">
                                            <i class="fa fa-microchip text-primary me-2"/>
                                            <strong t-out="plan.cpu_limit"/> CPU
                                            <t t-if="plan.cpu_limit == 1"> Core</t>
                                            <t t-else=""> Cores</t>
                                        </li>
                                        <li class="mb-2">
                                            <i class="fa fa-memory text-primary me-2"/>
                                            <t t-out="plan.ram_limit.upper() if plan.ram_limit else 'N/A'"/> RAM
                                        </li>
                                        <li class="mb-2">
                                            <i class="fa fa-hdd-o text-primary me-2"/>
                                            <t t-out="int(plan.storage_limit)"/> GB Storage
                                        </li>
                                        <li class="mb-2">
                                            <i class="fa fa-cloud-download text-primary me-2"/>
                                            <t t-out="plan.max_backups"/> Daily Backups
                                        </li>
                                        <li t-if="plan.max_users" class="mb-2">
                                            <i class="fa fa-users text-primary me-2"/>
                                            <t t-out="plan.max_users"/> Users
                                        </li>
                                        <li t-if="plan.feature_api_access" class="mb-2">
                                            <i class="fa fa-plug text-success me-2"/>
                                            API Access
                                        </li>
                                        <li t-if="plan.feature_custom_domain" class="mb-2">
                                            <i class="fa fa-globe text-success me-2"/>
                                            Custom Domain
                                        </li>
                                        <li t-if="plan.feature_custom_modules" class="mb-2">
                                            <i class="fa fa-puzzle-piece text-success me-2"/>
                                            Custom Modules
                                        </li>
                                    </ul>

                                    <!-- CTA: Get Started -->
                                    <a t-attf-href="/services/#{product.id}/plans/#{plan.id}/configure"
                                       class="btn btn-primary btn-lg w-100 mt-auto">
                                        Get Started
                                    </a>

                                    <!-- CTA: Free Trial -->
                                    <a t-if="trial_available"
                                       t-attf-href="/services/#{product.id}/plans/#{plan.id}/configure?trial=1"
                                       class="btn btn-outline-success w-100 mt-2">
                                        <i class="fa fa-gift me-1"/>
                                        Start Free Trial
                                        (<t t-out="trial_days"/> days)
                                    </a>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <t t-if="not plans">
                    <div class="text-center text-muted py-5">
                        <p class="lead">
                            No plans available for this service yet. Please check back later.
                        </p>
                    </div>
                </t>
            </div>

        </t>
    </template>

    <!-- ============================================================ -->
    <!--  3. Configure Instance  –  /services/<id>/plans/<pid>/configure -->
    <!-- ============================================================ -->

    <template id="service_configure_form" name="Configure Your Instance">
        <t t-call="website.layout">
            <t t-set="additional_title">Configure Instance</t>

            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8">

                        <!-- Breadcrumb-style navigation -->
                        <nav aria-label="breadcrumb" class="mb-4">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item">
                                    <a href="/services">Services</a>
                                </li>
                                <li class="breadcrumb-item">
                                    <a t-attf-href="/services/#{product.id}">
                                        <t t-out="product.name"/>
                                    </a>
                                </li>
                                <li class="breadcrumb-item active" aria-current="page">
                                    Configure
                                </li>
                            </ol>
                        </nav>

                        <!-- Service + Plan Summary -->
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body d-flex align-items-center">
                                <div class="me-3">
                                    <t t-if="product.image">
                                        <img t-att-src="'data:image/png;base64,%s' % product.image.decode()"
                                             class="rounded"
                                             style="max-height:40px;"
                                             t-att-alt="product.name"/>
                                    </t>
                                    <t t-else="">
                                        <i t-att-class="'%s fa-2x text-primary' % (product.icon or 'fa fa-cogs')"/>
                                    </t>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mb-1">
                                        <t t-out="product.name"/>
                                        <span class="text-muted mx-1">|</span>
                                        <strong t-field="plan.name"/>
                                    </h5>
                                    <span class="text-muted">
                                        <t t-if="plan.currency_id" t-out="plan.currency_id.symbol"/>
                                        <t t-out="'%.2f' % plan.price"/>
                                        / <t t-if="plan.billing_period == 'monthly'">month</t>
                                          <t t-if="plan.billing_period == 'yearly'">year</t>
                                        <span class="mx-2">|</span>
                                        <t t-out="plan.cpu_limit"/> CPU,
                                        <t t-out="plan.ram_limit"/> RAM,
                                        <t t-out="int(plan.storage_limit)"/> GB Storage
                                    </span>
                                </div>
                                <a t-attf-href="/services/#{product.id}"
                                   class="btn btn-outline-secondary btn-sm">
                                    Change Plan
                                </a>
                            </div>
                        </div>

                        <!-- Trial Badge -->
                        <div t-if="is_trial" class="alert alert-success d-flex align-items-center mb-4">
                            <i class="fa fa-gift fa-2x me-3"/>
                            <div>
                                <strong>Free Trial</strong> — You will get a fully
                                functional instance at no cost. No credit card required.
                            </div>
                        </div>

                        <!-- Error message -->
                        <div t-if="error" class="alert alert-danger" role="alert">
                            <t t-out="error"/>
                        </div>

                        <!-- Configuration Form -->
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white">
                                <h4 class="mb-0">Configure Your Instance</h4>
                            </div>
                            <div class="card-body">
                                <form action="/services/order" method="POST">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="product_id"
                                           t-att-value="product.id"/>
                                    <input type="hidden" name="plan_id"
                                           t-att-value="plan.id"/>
                                    <input t-if="is_trial" type="hidden"
                                           name="is_trial" value="1"/>

                                    <!-- Subdomain -->
                                    <div class="mb-4">
                                        <label for="subdomain" class="form-label fw-bold">
                                            Subdomain
                                        </label>
                                        <div class="input-group">
                                            <input type="text" name="subdomain" id="subdomain"
                                                   class="form-control form-control-lg"
                                                   placeholder="your-company"
                                                   required="required"
                                                   pattern="[a-z0-9]([a-z0-9\-]{0,61}[a-z0-9])?"
                                                   t-att-value="form_values.get('subdomain', '')"
                                                   autocomplete="off"/>
                                            <span class="input-group-text" id="domain-suffix">
                                                .<t t-if="domains" t-out="domains[0].name"/>
                                            </span>
                                        </div>
                                        <div id="subdomain-feedback" class="form-text"></div>
                                        <small class="text-muted">
                                            Lowercase letters, digits, and hyphens only.
                                        </small>
                                    </div>

                                    <!-- Base Domain -->
                                    <div class="mb-4">
                                        <label for="domain_id" class="form-label fw-bold">
                                            Base Domain
                                        </label>
                                        <select name="domain_id" id="domain_id"
                                                class="form-select" required="required">
                                            <t t-foreach="domains" t-as="domain">
                                                <option t-att-value="domain.id"
                                                        t-att-selected="str(domain.id) == str(form_values.get('domain_id', domains[0].id if domains else ''))">
                                                    <t t-out="domain.name"/>
                                                </option>
                                            </t>
                                        </select>
                                    </div>

                                    <!-- Submit -->
                                    <button t-if="is_trial" type="submit"
                                            class="btn btn-success btn-lg w-100">
                                        <i class="fa fa-gift me-2"/>Start Free Trial
                                    </button>
                                    <button t-else="" type="submit"
                                            class="btn btn-primary btn-lg w-100">
                                        <i class="fa fa-lock me-2"/>Continue to Payment
                                    </button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </t>
    </template>

</odoo>
