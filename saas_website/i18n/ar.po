msgstr "انتظر تأكيد الدفع، أو ادفع الفاتورة يدويًا."

#: model_terms:ir.ui.view,arch_db:saas_website.cloudodoo_layout
msgid "Deployment failed after several auto-retries."
msgstr "فشل النشر بعد عدّة محاولات تلقائية."

#: model_terms:ir.ui.view,arch_db:saas_website.cloudodoo_layout
msgid "Contact support — we'll investigate."
msgstr "تواصل مع الدعم — سنحقّق في الأمر."

