# Translation of SaaS Website module into Arabic (Modern Standard Arabic).
# This file translates every customer-visible string in the saas_website
# module from English (en_US) into Arabic (ar_001). Strings are grouped by
# section in the order they appear to a customer, not alphabetically, so
# a translator updating this file can follow the user journey end-to-end.
#
# Format: GNU gettext (.po). Loaded automatically by Odoo when the active
# language is ar_001 and saas_website is installed/updated.
msgid ""
msgstr ""
"Project-Id-Version: saas_website\n"
"Report-Msgid-Bugs-To: \n"
