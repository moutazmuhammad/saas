#: model_terms:ir.ui.view,arch_db:saas_website.cloudodoo_layout
msgid "Database '%s' does not exist on this instance."
msgstr "قاعدة البيانات «%s» غير موجودة في هذا الحساب."

#: model_terms:ir.ui.view,arch_db:saas_website.cloudodoo_layout
