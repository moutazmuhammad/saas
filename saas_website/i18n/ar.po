# ============================================================
# Errors / notices
# ============================================================
msgid "Backup not available."
msgstr "النسخة الاحتياطية غير متاحة."

msgid "Backup not found."
msgstr "لم يُعثر على النسخة الاحتياطية."

msgid "Backup cancelled."
msgstr "تم إلغاء النسخة الاحتياطية."

msgid "Restore started. Refresh in a moment."
msgstr "بدأت عملية الاستعادة. حدّث الصفحة بعد لحظات."

msgid "Restore could not be started. Please try again or contact support if the problem continues."
msgstr "تعذّر بدء الاستعادة. حاول مرة أخرى أو تواصل مع الدعم إن استمرّت المشكلة."

msgid "Instance must be Running or Stopped to restore."
msgstr "يجب أن يكون الحساب قيد التشغيل أو متوقفًا للاستعادة."

msgid "Type the database name exactly to confirm restore."
msgstr "اكتب اسم قاعدة البيانات بالضبط لتأكيد الاستعادة."

msgid "Pick a database to back up."
msgstr "اختر قاعدة البيانات المراد نسخها."

msgid "Pick a database to reset."
msgstr "اختر قاعدة البيانات المراد إعادة تعيين كلمة مرورها."

msgid "Both database and module are required."
msgstr "قاعدة البيانات والخاصية كلاهما مطلوبان."

msgid "New password and confirmation don't match."
msgstr "كلمة المرور الجديدة وتأكيدها غير متطابقتين."

msgid "Storage cannot be reduced. Current storage: %d GB."
msgstr "لا يمكن تقليل السعة التخزينية. السعة الحالية: %d جيجابايت."

msgid "Please configure your plan."
msgstr "الرجاء إعداد خطتك."

msgid "No changes selected."
msgstr "لا توجد تغييرات محددة."

msgid "Daily backups are not available on trial plans."
msgstr "النسخ اليومية غير متاحة في خطط التجربة."

msgid "Daily backups can't be disabled from the portal. Contact support if you need to make a change."
msgstr "لا يمكن إيقاف النسخ اليومية من بوابة العميل. تواصل مع الدعم إن احتجت إلى تغيير."

msgid "Pending payment cancelled. You can re-enable daily backups any time."
msgstr "تم إلغاء الدفع المعلّق. يمكنك تفعيل النسخ اليومية مجددًا في أي وقت."

msgid "Restore failed — see instance logs."
msgstr "فشلت الاستعادة — راجع سجل النشاط."

msgid "We couldn't generate the download link right now. Please try again in a moment, or contact support."
msgstr "تعذّر توليد رابط التحميل الآن. أعد المحاولة لاحقًا أو تواصل مع الدعم."

msgid "This operation didn't finish in time. If the database isn't there yet, dismiss this and try again."
msgstr "لم تنتهِ العملية في الوقت المتوقّع. إن لم تظهر قاعدة البيانات بعد، أغلق هذا الإشعار وأعد المحاولة."

# ============================================================
# Notice messages (controller)
# ============================================================
msgid "Database '%s' does not exist on this instance."
msgstr "قاعدة البيانات «%s» غير موجودة في هذا الحساب."

msgid "Database '%s' does not belong to this instance."
msgstr "قاعدة البيانات «%s» لا تنتمي إلى هذا الحساب."

msgid "A backup of '%s' is still in progress. Wait for it to finish before starting another."
msgstr "نسخة احتياطية لـ«%s» قيد التنفيذ. انتظر انتهاءها قبل بدء أخرى."

msgid "Backup of '%(db)s' started. Refresh in a minute — a download link valid for 24 hours will appear once ready."
msgstr "بدأت نسخة «%(db)s». حدّث الصفحة بعد دقيقة — سيظهر رابط تحميل صالح لمدة ٢٤ ساعة عند الجهوزية."

msgid "Replaced by a newer on-demand backup request."
msgstr "تم استبدالها بطلب نسخة فورية أحدث."

msgid "Pick a database to back up."
msgstr "اختر قاعدة البيانات المراد نسخها."

msgid "Instance must be running to create a backup."
msgstr "يجب أن يكون الحساب قيد التشغيل لإنشاء نسخة احتياطية."

msgid "On-demand backups are available for hosting instances only."
msgstr "النسخ الاحتياطية الفورية متاحة لحسابات الاستضافة فقط."

msgid "Admin password reset for '%(db)s'. Sign in as '%(login)s' with your new password."
msgstr "تم إعادة تعيين كلمة مرور المسؤول لـ«%(db)s». سجّل الدخول باسم «%(login)s» بكلمة المرور الجديدة."

msgid "Repairing '%(module)s' on '%(db)s'… your instance will come back up automatically. This page auto-refreshes."
msgstr "جاري إصلاح «%(module)s» في «%(db)s»… سيعود حسابك تلقائيًا. ستُحدَّث الصفحة تلقائيًا."

msgid "Deleting database '%s'…"
msgstr "جاري حذف قاعدة البيانات «%s»…"

msgid "Duplicating to '%s'… refresh to see progress."
msgstr "جاري النسخ إلى «%s»… حدّث الصفحة لمتابعة التقدّم."

msgid "Creating database '%s'… this takes about a minute. Refresh the page to see its progress."
msgstr "جاري إنشاء قاعدة البيانات «%s»… تستغرق حوالي دقيقة. حدّث الصفحة لمتابعة التقدّم."

