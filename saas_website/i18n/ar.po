msgstr "لا يمكن تقليل السعة التخزينية. السعة الحالية: %d جيجابايت."

#: model_terms:ir.ui.view,arch_db:saas_website.cloudodoo_layout
msgid "Please configure your plan."
msgstr "الرجاء إعداد خطتك."

#: model_terms:ir.ui.view,arch_db:saas_website.cloudodoo_layout
msgid "No changes selected."
msgstr "لا توجد تغييرات محددة."

#: model_terms:ir.ui.view,arch_db:saas_website.cloudodoo_layout
msgid "Daily backups are not available on trial plans."
msgstr "النسخ اليومية غير متاحة في خطط التجربة."

#: model_terms:ir.ui.view,arch_db:saas_website.cloudodoo_layout
msgid "Daily backups can't be disabled from the portal. Contact support if you need to make a change."
