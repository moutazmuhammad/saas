<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Recurring billing: generate renewal invoices -->
    <record id="ir_cron_saas_recurring_billing" model="ir.cron">
        <field name="name">SaaS: Generate Recurring Invoices</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="state">code</field>
        <field name="code">model._cron_generate_recurring_invoices()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <!-- Dunning: check overdue invoices and suspend after grace period -->
    <record id="ir_cron_saas_dunning" model="ir.cron">
        <field name="name">SaaS: Check Overdue Invoices (Dunning)</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_overdue_invoices()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <!-- Daily-backup add-on: monthly renewal invoices, independent of the
         main subscription billing cycle. -->
    <record id="ir_cron_saas_daily_backup_renewal" model="ir.cron">
        <field name="name">SaaS: Renew Daily-Backup Add-on (Monthly)</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="state">code</field>
        <field name="code">model._cron_renew_daily_backup_addons()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
