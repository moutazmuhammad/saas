<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Recurring billing: generate renewal invoices -->
    <record id="ir_cron_saas_recurring_billing" model="ir.cron">
        <field name="name">SaaS: Generate Recurring Invoices</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="state">code</field>
        <field name="code">model._cron_generate_recurring_invoices()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <!-- Dunning: check overdue invoices and suspend after grace period -->
    <record id="ir_cron_saas_dunning" model="ir.cron">
        <field name="name">SaaS: Check Overdue Invoices (Dunning)</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_overdue_invoices()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <!-- Zombie reaper: any database operation (create/duplicate/drop/
         upgrade) still in 'running' state past the timeout is auto-
         failed so the customer's portal stops showing an eternal
         spinner. Safety net for crashed background threads. -->
    <record id="ir_cron_saas_db_op_zombie_reaper" model="ir.cron">
        <field name="name">SaaS: Reap Stuck Database Operations</field>
        <field name="model_id" ref="saas_core.model_saas_instance_db_operation"/>
        <field name="state">code</field>
        <field name="code">model._cron_reap_stuck_db_operations()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>

    <!-- Safety net: apply pending plan changes whose invoice is paid but
         where the payment hook never (fully) ran — without this a paying
         customer can stay stuck on the old plan forever. -->
    <record id="ir_cron_saas_apply_paid_pending_changes" model="ir.cron">
        <field name="name">SaaS: Apply Paid Pending Plan Changes (Safety Net)</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="state">code</field>
        <field name="code">model._cron_apply_paid_pending_changes()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>

    <!-- Auto-renew reminders: notify customers 7 days and 1 day before the
         renewal date (A1). -->
    <record id="ir_cron_saas_renewal_reminders" model="ir.cron">
        <field name="name">SaaS: Send Renewal Reminders (7d / 1d)</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_renewal_reminders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <!-- Auto-renew retry: re-charge unpaid mandatory invoices on the
         retry schedule (1, 3, 5 days after the invoice date), all inside
         the grace period (A1). -->
    <record id="ir_cron_saas_payment_retry" model="ir.cron">
        <field name="name">SaaS: Retry Failed Auto-renew Payments</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="state">code</field>
        <field name="code">model._cron_retry_failed_payments()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <!-- Daily-backup add-on: monthly renewal invoices, independent of the
         main subscription billing cycle. -->
    <record id="ir_cron_saas_daily_backup_renewal" model="ir.cron">
        <field name="name">SaaS: Renew Daily-Backup Add-on (Monthly)</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="state">code</field>
        <field name="code">model._cron_renew_daily_backup_addons()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
