<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Refresh each infra server's reachability so allocation + region
         capacity can cheaply skip dead hosts. A customer is never placed on
         a host we already know is down (their deploy would just strand in
         "pending provision"). -->
    <record id="ir_cron_saas_server_health" model="ir.cron">
        <field name="name">SaaS: Server Health Check (reachability)</field>
        <field name="model_id" ref="model_saas_server"/>
        <field name="state">code</field>
        <field name="code">model._cron_health_check()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

</odoo>
