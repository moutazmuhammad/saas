<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ir_cron_saas_backup" model="ir.cron">
        <field name="name">SaaS: Auto Backup Instances</field>
        <field name="model_id" ref="model_saas_instance_backup"/>
        <field name="state">code</field>
        <field name="code">model._cron_backup_all_instances()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <!-- Fire at 03:00 UTC daily. Move this in
             Settings → Technical → Scheduled Actions if your business
             hours sit in a non-UTC timezone. -->
        <field name="nextcall" eval="(DateTime.now().replace(hour=3, minute=0, second=0, microsecond=0) + relativedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="active">True</field>
    </record>

    <!-- Hidden safety monitor: flag instances whose backup footprint
         outgrew their plan so the dashboard can nudge an upgrade. Runs an
         hour after the 03:00 backup so footprints are fresh. Pure internal
         check — no customer-facing metering, no charge. -->
    <record id="ir_cron_saas_backup_budget_check" model="ir.cron">
        <field name="name">SaaS: Check Backup Budgets</field>
        <field name="model_id" ref="model_saas_instance"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_backup_budgets()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(DateTime.now().replace(hour=4, minute=0, second=0, microsecond=0) + relativedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="active">True</field>
    </record>

    <!-- On-demand backups have a fixed 1-hour download window. After
         that, the bucket object is reaped and the local record removed
         so we don't accumulate orphans. 5-minute granularity is plenty:
         worst case a customer's expired link survives 5 extra minutes. -->
    <record id="ir_cron_saas_backup_ephemeral" model="ir.cron">
        <field name="name">SaaS: Reap Expired On-Demand Backups</field>
        <field name="model_id" ref="model_saas_instance_backup"/>
        <field name="state">code</field>
        <field name="code">model._cron_cleanup_ephemeral_backups()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

</odoo>
