<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <!-- ============================================================ -->
    <!--  Instance Deployed Successfully                               -->
    <!-- ============================================================ -->
    <record id="mail_template_saas_deployed" model="mail.template">
        <field name="name">SaaS: Instance Deployed</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="subject">Your instance {{ object.name }} is ready!</field>
        <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
        <field name="body_html" type="html">
<div style="margin: 0; padding: 0; font-family: Arial, sans-serif;">
    <p>Dear <t t-out="object.partner_id.name"/>,</p>
    <p>Great news! Your instance <strong><t t-out="object.name"/></strong> has been
       deployed successfully and is now running.</p>
    <p><strong>Access URL:</strong>
       <a t-att-href="object.url"><t t-out="object.url"/></a></p>
    <p>Plan: <t t-out="object.plan_id.name or 'N/A'"/></p>

    <t t-if="object.is_hosting">
        <hr style="margin:16px 0;border:0;border-top:1px solid #ddd;"/>
        <p><strong>Your instance starts empty.</strong> Create as many
           Odoo databases as you need from the database manager:</p>
        <p>
            <a t-attf-href="{{ object.url }}/web/database/manager"
               t-attf-style="display:inline-block;padding:10px 16px;background:#10B981;color:white;text-decoration:none;border-radius:6px;">
                Open Database Manager
            </a>
        </p>
        <p>When prompted for the <em>master password</em>, use:</p>
        <p style="font-family:monospace;background:#f4f4f5;padding:10px;border-radius:6px;display:inline-block;">
            <t t-out="object.sudo().admin_password"/>
        </p>
        <p style="color:#666;font-size:13px;">
            Keep this password safe — it's required to create, duplicate,
            restore or delete databases on your instance. We never share
            it again by email.
        </p>
    </t>

    <p>You can manage your instance from the
       <a t-attf-href="/my/instances/{{ object.id }}">customer portal</a>.</p>
    <t t-set="support_email" t-value="object.env['ir.config_parameter'].sudo().get_param('saas_master.support_email', '')"/>
    <p t-if="support_email">Need help? Contact us at
       <a t-att-href="'mailto:' + support_email"><t t-out="support_email"/></a>.</p>
    <p>Best regards,<br/><t t-out="object.company_id.name"/></p>
</div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <!-- ============================================================ -->
    <!--  Instance Suspended                                           -->
    <!-- ============================================================ -->
    <record id="mail_template_saas_suspended" model="mail.template">
        <field name="name">SaaS: Instance Suspended</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="subject">Your instance {{ object.name }} has been suspended</field>
        <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
        <field name="body_html" type="html">
<div style="margin: 0; padding: 0; font-family: Arial, sans-serif;">
    <t t-set="support_email" t-value="object.env['ir.config_parameter'].sudo().get_param('saas_master.support_email', '')"/>
    <p>Dear <t t-out="object.partner_id.name"/>,</p>
    <p>Your instance <strong><t t-out="object.name"/></strong> has been
       <strong>suspended</strong>.</p>
    <p>This may be due to:</p>
    <ul>
        <li>Free trial expiry</li>
        <li>Overdue payment past grace period</li>
    </ul>
    <p>To reactivate your instance, please settle any outstanding invoices
       or upgrade your plan.</p>
    <p>Visit the <a t-attf-href="/my/instances/{{ object.id }}">customer portal</a>
       for more details.</p>
    <p t-if="support_email">Need help? Contact us at
       <a t-att-href="'mailto:' + support_email"><t t-out="support_email"/></a>.</p>
    <p>Best regards,<br/><t t-out="object.company_id.name"/></p>
</div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <!-- ============================================================ -->
    <!--  Payment Due / Overdue Warning                                -->
    <!-- ============================================================ -->
    <record id="mail_template_saas_payment_due" model="mail.template">
        <field name="name">SaaS: Payment Due</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="subject">Payment due for your instance {{ object.name }}</field>
        <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
        <field name="body_html" type="html">
<div style="margin: 0; padding: 0; font-family: Arial, sans-serif;">
    <t t-set="support_email" t-value="object.env['ir.config_parameter'].sudo().get_param('saas_master.support_email', '')"/>
    <t t-set="grace_days" t-value="object.env['ir.config_parameter'].sudo().get_param('saas_master.grace_period_days', '7')"/>
    <p>Dear <t t-out="object.partner_id.name"/>,</p>
    <p>This is a reminder that payment is due for your instance
       <strong><t t-out="object.name"/></strong>.</p>
    <p>Plan: <t t-out="object.plan_id.name or 'N/A'"/></p>
    <p>Please settle any outstanding invoices to avoid service interruption.
       Your instance may be suspended if payment is not received within the
       grace period (<t t-out="grace_days"/> days).</p>
    <p>Visit the <a t-attf-href="/my/instances/{{ object.id }}">customer portal</a>
       to view your invoices and make a payment.</p>
    <p t-if="support_email">Need help? Contact us at
       <a t-att-href="'mailto:' + support_email"><t t-out="support_email"/></a>.</p>
    <p>Best regards,<br/><t t-out="object.company_id.name"/></p>
</div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <!-- ============================================================ -->
    <!--  Deletion Warning                                             -->
    <!-- ============================================================ -->
    <record id="mail_template_saas_deletion_warning" model="mail.template">
        <field name="name">SaaS: Deletion Warning</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="subject">WARNING: Your instance {{ object.name }} will be deleted</field>
        <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
        <field name="body_html" type="html">
<div style="margin: 0; padding: 0; font-family: Arial, sans-serif;">
    <t t-set="support_email" t-value="object.env['ir.config_parameter'].sudo().get_param('saas_master.support_email', '')"/>
    <p>Dear <t t-out="object.partner_id.name"/>,</p>
    <p><strong>Your instance <t t-out="object.name"/> is scheduled for deletion.</strong></p>
    <p>All data, databases, and backups will be permanently removed.</p>
    <p t-if="support_email">If you wish to keep your instance, please contact us at
       <a t-att-href="'mailto:' + support_email"><t t-out="support_email"/></a>
       or settle outstanding invoices immediately.</p>
    <p t-else="">If you wish to keep your instance, please settle outstanding invoices immediately.</p>
    <p>Best regards,<br/><t t-out="object.company_id.name"/></p>
</div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <!-- ============================================================ -->
    <!--  Client Cancelled Payment (internal notification to support) -->
    <!-- ============================================================ -->
    <record id="mail_template_saas_payment_cancelled" model="mail.template">
        <field name="name">SaaS: Client Cancelled Payment (Internal)</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="subject">[Action Required] Client cancelled payment — {{ object.name }}</field>
        <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
        <field name="email_to">{{ (object.company_id.email or user.email) }}</field>
        <field name="body_html" type="html">
<div style="margin: 0; padding: 0; font-family: Arial, sans-serif;">
    <t t-set="last_invoice" t-value="object.sale_order_id.invoice_ids.sorted('create_date', reverse=True)[:1] if object.sale_order_id and object.sale_order_id.invoice_ids else None"/>
    <t t-if="object.pending_plan_id">
        <p><b>Client cancelled plan upgrade payment</b></p>
        <table style="border-collapse: collapse; margin: 12px 0;">
            <tr><td style="padding: 4px 12px 4px 0; font-weight: bold;">Client</td>
                <td><t t-out="object.partner_id.name"/> (<t t-out="object.partner_id.email or 'N/A'"/>)</td></tr>
            <tr><td style="padding: 4px 12px 4px 0; font-weight: bold;">Phone</td>
                <td><t t-out="object.partner_id.phone or object.partner_id.mobile or 'N/A'"/></td></tr>
            <tr><td style="padding: 4px 12px 4px 0; font-weight: bold;">Instance</td>
                <td><t t-out="object.name or object.subdomain"/></td></tr>
            <tr><td style="padding: 4px 12px 4px 0; font-weight: bold;">Was upgrading to</td>
                <td><b><t t-out="object.pending_plan_id.name"/></b> (<t t-out="object.pending_billing_period or object.billing_period or 'monthly'"/>)</td></tr>
            <tr t-if="last_invoice">
                <td style="padding: 4px 12px 4px 0; font-weight: bold;">Invoice</td>
                <td><t t-out="last_invoice.name"/> — <t t-out="last_invoice.currency_id.symbol or ''"/><t t-out="'%.2f' % last_invoice.amount_total"/></td></tr>
            <tr><td style="padding: 4px 12px 4px 0; font-weight: bold;">Current plan</td>
                <td><t t-out="object.plan_id.name or 'N/A'"/></td></tr>
        </table>
    </t>
    <t t-elif="object.state in ('pending_payment', 'draft')">
        <p><b>Client cancelled new subscription payment</b></p>
        <table style="border-collapse: collapse; margin: 12px 0;">
            <tr><td style="padding: 4px 12px 4px 0; font-weight: bold;">Client</td>
                <td><t t-out="object.partner_id.name"/> (<t t-out="object.partner_id.email or 'N/A'"/>)</td></tr>
            <tr><td style="padding: 4px 12px 4px 0; font-weight: bold;">Phone</td>
                <td><t t-out="object.partner_id.phone or object.partner_id.mobile or 'N/A'"/></td></tr>
            <tr><td style="padding: 4px 12px 4px 0; font-weight: bold;">Instance</td>
                <td><t t-out="object.name or object.subdomain"/></td></tr>
            <tr><td style="padding: 4px 12px 4px 0; font-weight: bold;">Plan</td>
                <td><b><t t-out="object.plan_id.name or 'N/A'"/></b> (<t t-out="object.billing_period or 'monthly'"/>)</td></tr>
            <tr t-if="last_invoice">
                <td style="padding: 4px 12px 4px 0; font-weight: bold;">Invoice</td>
                <td><t t-out="last_invoice.name"/> — <t t-out="last_invoice.currency_id.symbol or ''"/><t t-out="'%.2f' % last_invoice.amount_total"/></td></tr>
        </table>
    </t>
    <t t-else="">
        <p><b>Client cancelled a payment</b></p>
        <table style="border-collapse: collapse; margin: 12px 0;">
            <tr><td style="padding: 4px 12px 4px 0; font-weight: bold;">Client</td>
                <td><t t-out="object.partner_id.name"/> (<t t-out="object.partner_id.email or 'N/A'"/>)</td></tr>
            <tr><td style="padding: 4px 12px 4px 0; font-weight: bold;">Phone</td>
                <td><t t-out="object.partner_id.phone or object.partner_id.mobile or 'N/A'"/></td></tr>
            <tr><td style="padding: 4px 12px 4px 0; font-weight: bold;">Instance</td>
                <td><t t-out="object.name or object.subdomain"/></td></tr>
            <tr><td style="padding: 4px 12px 4px 0; font-weight: bold;">Plan</td>
                <td><t t-out="object.plan_id.name or 'N/A'"/></td></tr>
            <tr t-if="last_invoice">
                <td style="padding: 4px 12px 4px 0; font-weight: bold;">Invoice</td>
                <td><t t-out="last_invoice.name"/> — <t t-out="last_invoice.currency_id.symbol or ''"/><t t-out="'%.2f' % last_invoice.amount_total"/></td></tr>
        </table>
    </t>
    <p>Please follow up to help close the sale.</p>
    <p>View the instance in the backend:
       <a t-attf-href="/odoo/saas-instance-manager/{{ object.id }}">
           <t t-out="object.name or object.subdomain"/>
       </a>
    </p>
</div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <!-- ============================================================ -->
    <!--  Auto-renew reminder (7 days / 1 day before renewal) (A1)     -->
    <!-- ============================================================ -->
    <record id="mail_template_saas_renewal_reminder" model="mail.template">
        <field name="name">SaaS: Renewal Reminder</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="subject">Your subscription for {{ object.name }} renews on {{ object.next_invoice_date }}</field>
        <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
        <field name="body_html" type="html">
<div style="margin: 0; padding: 0; font-family: Arial, sans-serif;">
    <t t-set="support_email" t-value="object.env['ir.config_parameter'].sudo().get_param('saas_master.support_email', '')"/>
    <p>Dear <t t-out="object.partner_id.name"/>,</p>
    <p>Your subscription for <strong><t t-out="object.name"/></strong>
       (<t t-out="object.plan_id.name or 'N/A'"/>,
       <t t-out="dict(object._fields['billing_period'].selection).get(object.billing_period, object.billing_period)"/>)
       is scheduled to renew on
       <strong><t t-out="object.next_invoice_date"/></strong>.</p>
    <p t-if="object.auto_renew_subscription and object._auto_renew_method()">
       We'll automatically charge your saved payment method
       (<t t-out="object._auto_renew_method().display_label or 'on file'"/>)
       on the renewal date. No action is needed.</p>
    <p t-else="">
       Auto-renew is off (or no payment method is saved), so please pay the
       renewal invoice from the
       <a t-attf-href="/my/instances/{{ object.id }}">customer portal</a>
       to avoid any interruption.</p>
    <p>You can review or change your plan, payment method and auto-renew
       setting any time in the portal.</p>
    <p t-if="support_email">Questions? Contact us at
       <a t-att-href="'mailto:' + support_email"><t t-out="support_email"/></a>.</p>
    <p>Best regards,<br/><t t-out="object.company_id.name"/></p>
</div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <!-- ============================================================ -->
    <!--  Capacity "upgrade experience" — positive framing only (v47)  -->
    <!--  Shared body: the capacity summary supplies title + message,  -->
    <!--  and both CTAs (Upgrade / Add storage) are always present.    -->
    <!-- ============================================================ -->
    <template id="saas_capacity_email_body">
        <div style="margin:0;padding:0;font-family:Arial,sans-serif;">
            <t t-set="cap" t-value="object._capacity_summary()"/>
            <t t-set="support_email" t-value="object.env['ir.config_parameter'].sudo().get_param('saas_master.support_email', '')"/>
            <p>Hi <t t-out="object.partner_id.name"/>,</p>
            <p style="font-size:16px;"><strong><t t-out="cap['title']"/></strong></p>
            <p t-out="cap['message']"/>
            <p>You're using <strong><t t-out="'%.1f' % cap['used_gb']"/> GB</strong>
               of <strong><t t-out="'%g' % cap['capacity_gb']"/> GB</strong>
               (<t t-out="'%.0f' % cap['usage_pct']"/>%).</p>
            <p style="margin:24px 0;">
                <a t-attf-href="/my/instances/{{ object.id }}/change-plan"
                   style="background:#4f46e5;color:#fff;padding:10px 18px;border-radius:8px;text-decoration:none;margin-right:10px;">Upgrade plan</a>
                <a t-attf-href="/my/instances/{{ object.id }}/add-storage"
                   style="background:#0ea5e9;color:#fff;padding:10px 18px;border-radius:8px;text-decoration:none;">Add storage</a>
            </p>
            <p>You're always in control — pick whichever option fits best, and
               your workspace keeps scaling smoothly.</p>
            <p t-if="support_email">Questions? We're happy to help at
               <a t-att-href="'mailto:' + support_email"><t t-out="support_email"/></a>.</p>
            <p>— <t t-out="object.company_id.name"/></p>
        </div>
    </template>

    <record id="mail_template_saas_capacity_warn" model="mail.template">
        <field name="name">SaaS: Capacity — filling up (80%)</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="subject">Your workspace {{ object.name }} is filling up</field>
        <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
        <field name="body_html" type="html">
            <t t-call="saas_core.saas_capacity_email_body"/>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="mail_template_saas_capacity_full" model="mail.template">
        <field name="name">SaaS: Capacity — reached (100%)</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="subject">Time to expand your workspace {{ object.name }}</field>
        <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
        <field name="body_html" type="html">
            <t t-call="saas_core.saas_capacity_email_body"/>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="mail_template_saas_capacity_paused" model="mail.template">
        <field name="name">SaaS: Capacity — workspace paused</field>
        <field name="model_id" ref="saas_core.model_saas_instance"/>
        <field name="subject">Your workspace {{ object.name }} is paused — your data is safe</field>
        <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
        <field name="body_html" type="html">
            <t t-call="saas_core.saas_capacity_email_body"/>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <!-- ============================================================ -->
    <!--  Bonus wallet credit expiring soon (v47)                      -->
    <!--  Customer money NEVER expires — only labeled bonus credit.    -->
    <!-- ============================================================ -->
    <record id="mail_template_saas_wallet_bonus_expiring" model="mail.template">
        <field name="name">SaaS: Bonus Credit Expiring</field>
        <field name="model_id" ref="saas_core.model_saas_wallet"/>
        <field name="subject">You have bonus credit expiring soon</field>
        <field name="email_from">{{ (object.env.company.email or user.email) }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
        <field name="body_html" type="html">
<div style="margin:0;padding:0;font-family:Arial,sans-serif;">
    <p>Hi <t t-out="object.partner_id.name"/>,</p>
    <p>You have <strong><t t-out="object.currency_id.symbol or ''"/><t t-out="'%.2f' % object.balance_bonus"/></strong>
       of <strong>bonus credit</strong> that will expire soon. It is applied
       to your invoices automatically — no action needed to use it.</p>
    <p><strong>Your own balance never expires</strong> — only promotional
       bonus credit has an expiry date.</p>
    <p>Best regards,<br/><t t-out="object.env.company.name"/></p>
</div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

</odoo>
