<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Phase 4.3.4: flag tenants running at a loss (margin < 0). -->
    <record id="ir_cron_saas_margin_alert" model="ir.cron">
        <field name="name">SaaS: Flag Unprofitable Tenants</field>
        <field name="model_id" ref="model_saas_instance"/>
        <field name="state">code</field>
        <field name="code">model._cron_flag_unprofitable_tenants()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">weeks</field>
        <field name="active">True</field>
    </record>

</odoo>
