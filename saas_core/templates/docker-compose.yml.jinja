services:

  odoo:
    image: {{ odoo_image | default("odoo") }}:{{ odoo_version }}
    container_name: odoo_{{ subdomain }}
    restart: unless-stopped
    stop_grace_period: 30s
    ports:
      - "{{ host_ip | default('127.0.0.1') }}:{{ xmlrpc_port }}:8069"
      - "{{ host_ip | default('127.0.0.1') }}:{{ longpolling_port }}:8072"
    volumes:
      - /opt/odoo-source/{{ odoo_version }}:/opt/odoo:ro
      - ./data/odoo:/var/lib/odoo
{%- if filestore_mount %}
      # Phase 2: filestore on object storage (JuiceFS) — keeps compute disposable
      - {{ filestore_mount }}:/var/lib/odoo/filestore
{%- endif %}
      - ./config:/etc/odoo
      - ./addons:/mnt/extra-addons
      - ./requirements.txt:/etc/odoo/requirements.txt:ro
{%- if pip_packages %}
      - ./pip_install.sh:/etc/odoo/pip_install.sh:ro
    entrypoint: ["bash", "/etc/odoo/pip_install.sh"]
    environment:
      - PYTHONPATH=/var/lib/odoo/pip_packages
{%- endif %}
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:8069/web/login || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 120s
    extra_hosts:
      - "host.docker.internal:host-gateway"
    networks:
      - {{ network_name | default("net") }}
{%- if docker_cpu %}
    cpus: {{ docker_cpu }}
{%- endif %}
{%- if docker_mem %}
    mem_limit: {{ docker_mem }}
{%- endif %}
{%- if docker_swap %}
    memswap_limit: {{ docker_swap }}
{%- endif %}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"


networks:
  {{ network_name | default("net") }}:
    driver: bridge
