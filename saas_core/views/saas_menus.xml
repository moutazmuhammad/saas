<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Root Menu -->
    <menuitem id="saas_master_menu_root"
              name="SaaS Manager"
              sequence="50"
              web_icon="saas_core,static/description/icon.png"
              groups="base.group_user"/>

    <!-- Instances -->
    <menuitem id="saas_master_menu_instances"
              name="Instances"
              parent="saas_master_menu_root"
              sequence="10"/>

    <menuitem id="saas_master_menu_instances_all"
              name="All Instances"
              parent="saas_master_menu_instances"
              action="saas_instance_action"
              sequence="1"/>

    <menuitem id="saas_master_menu_instances_services"
              name="Service Instances"
              parent="saas_master_menu_instances"
              action="saas_instance_action_services"
              sequence="10"/>

    <menuitem id="saas_master_menu_instances_hosting"
              name="Hosting Instances"
              parent="saas_master_menu_instances"
              action="saas_instance_action_hosting"
              sequence="20"/>

    <!-- Configuration -->
    <menuitem id="saas_master_menu_configuration"
              name="Configuration"
              parent="saas_master_menu_root"
              sequence="90"/>

    <!-- Configuration > Services -->
    <menuitem id="saas_master_menu_services"
              name="Services"
              parent="saas_master_menu_configuration"
              action="saas_product_action"
              sequence="10"/>

    <!-- Configuration > Plans -->
    <menuitem id="saas_master_menu_plans"
              name="Plans"
              parent="saas_master_menu_configuration"
              action="saas_plan_action"
              sequence="20"/>

    <!-- Configuration > Add-ons -->
    <menuitem id="saas_master_menu_addons"
              name="Add-ons"
              parent="saas_master_menu_configuration"
              action="saas_addon_action"
              sequence="22"/>

    <!-- Configuration > Base Domains -->
    <menuitem id="saas_master_menu_based_domain"
              name="Base Domains"
              parent="saas_master_menu_configuration"
              action="saas_odoo_based_domain_action"
              sequence="30"/>

    <!-- Configuration > Odoo Versions -->
    <menuitem id="saas_master_menu_odoo_version"
              name="Odoo Versions"
              parent="saas_master_menu_configuration"
              action="saas_odoo_version_action"
              sequence="40"/>

    <!-- Configuration > Servers -->
    <menuitem id="saas_master_menu_servers"
              name="Servers"
              parent="saas_master_menu_configuration"
              action="saas_server_action"
              sequence="50"/>

    <!-- Configuration > Settings -->
    <menuitem id="saas_master_menu_settings"
              name="Settings"
              parent="saas_master_menu_configuration"
              action="action_saas_master_config_settings"
              sequence="70"/>

</odoo>
