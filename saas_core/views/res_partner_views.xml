<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_saas_trial" model="ir.ui.view">
        <field name="name">res.partner.form.saas.trial</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_saas_instances" type="object"
                        class="oe_stat_button" icon="fa-server"
                        groups="saas_core.group_saas_manager">
                    <field name="saas_instance_count" widget="statinfo" string="Instances"/>
                </button>
            </xpath>
            <xpath expr="//group[@name='sale']" position="after">
                <group name="saas_trial" string="SaaS Trial">
                    <field name="saas_trial_used"/>
                    <field name="saas_trial_end_date"
                           invisible="not saas_trial_used"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
