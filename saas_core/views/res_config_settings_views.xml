<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit base settings form to add SaaS settings -->
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.saas_core</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="50"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="SaaS Manager" string="SaaS Manager" name="saas_core">

                    <!-- ==================== Website Sections ==================== -->
                    <block title="Website Sections" name="saas_website_sections_container">
                        <setting id="saas_show_services_section_setting"
                                 string="Show Services Section"
                                 help="When off, the Services nav link, footer link, home-page card and /services routes are hidden. Data is preserved.">
                            <field name="saas_show_services_section"/>
                        </setting>
                        <setting id="saas_show_hosting_section_setting"
                                 string="Show Hosting Section"
                                 help="When off, the Hosting nav link, footer link, home-page card and /hosting routes are hidden. Data is preserved.">
                            <field name="saas_show_hosting_section"/>
                        </setting>
                    </block>

                    <!-- ==================== General ==================== -->
                    <block title="General" name="saas_general_container">
                        <setting id="saas_trial_days_setting"
                                 string="Free Trial Duration"
                                 help="Number of days for the free trial. After expiry the instance is suspended until the client pays.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_trial_days" string="Duration" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_trial_days" class="col-2"/>
                                    <span class="text-muted ms-1">days</span>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_max_instances_per_user_setting"
                                 string="Max Instances Per User"
                                 help="Maximum number of active instances a single customer can have. Set to 0 for unlimited.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_max_instances_per_user" string="Limit" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_max_instances_per_user" class="col-2"/>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_default_instance_starting_port_setting"
                                 string="Default Starting Port"
                                 help="First port number used when auto-assigning HTTP / longpolling ports to new instances.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_default_instance_starting_port" string="Port" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_default_instance_starting_port" class="col-2"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- ==================== Support ==================== -->
                    <block title="Support" name="saas_support_container">
                        <setting id="saas_support_email_setting"
                                 string="Support Email"
                                 help="Email shown to clients in notifications and portal pages when they need to contact support.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_support_email" string="Email" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_support_email" class="col-4" placeholder="support@example.com"/>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_data_restoration_fee_setting"
                                 string="Data Restoration Fee"
                                 help="Fee charged when restoring data from a retained backup to a client's new instance. An invoice is generated automatically.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_data_restoration_fee" string="Fee" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_data_restoration_fee" class="col-2"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- ==================== Custom Plan Builder ==================== -->
                    <block title="Custom Plan Builder" name="saas_custom_plan_container">
                        <setting id="saas_worker_price_setting"
                                 string="Worker Pricing"
                                 help="Monthly price per Odoo worker for the custom plan builder on the pricing page.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_worker_price" string="Price per Worker" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_worker_price" class="col-2"/>
                                    <span class="text-muted ms-1">/ month</span>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_storage_price_per_gb_setting_custom"
                                 string="Storage Pricing"
                                 help="Monthly price per GB of storage for the custom plan builder.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_storage_price_per_gb" string="Price per GB" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_storage_price_per_gb" class="col-2"/>
                                    <span class="text-muted ms-1">/ month</span>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_custom_plan_workers_range_setting"
                                 string="Workers Range"
                                 help="Min/max workers allowed in the custom plan builder.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_custom_plan_min_workers" string="Min Workers" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_custom_plan_min_workers" class="col-2"/>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_custom_plan_max_workers" string="Max Workers" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_custom_plan_max_workers" class="col-2"/>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_custom_plan_storage_range_setting"
                                 string="Storage Range"
                                 help="Min/max storage (GB) allowed in the custom plan builder.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_custom_plan_min_storage" string="Min Storage (GB)" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_custom_plan_min_storage" class="col-2"/>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_custom_plan_max_storage" string="Max Storage (GB)" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_custom_plan_max_storage" class="col-2"/>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_custom_plan_resource_allocation_setting"
                                 string="Resource Allocation per Worker"
                                 help="How much CPU and RAM each worker gets in custom plans. These values are used when auto-creating plan records.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_custom_plan_cpu_per_worker" string="CPU per Worker" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_custom_plan_cpu_per_worker" class="col-2"/>
                                    <span class="text-muted ms-1">vCPU</span>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_custom_plan_ram_per_worker" string="RAM per Worker" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_custom_plan_ram_per_worker" class="col-2"/>
                                    <span class="text-muted ms-1">MB</span>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_custom_plan_backups_setting"
                                 string="Backups (scales with plan size)"
                                 help="Backups scale dynamically: smallest plan gets min, largest gets max. Plans in between are interpolated.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_custom_plan_min_backups" string="Smallest plan" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_custom_plan_min_backups" class="col-2"/>
                                    <span class="text-muted ms-1">backups</span>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_custom_plan_max_backups" string="Largest plan" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_custom_plan_max_backups" class="col-2"/>
                                    <span class="text-muted ms-1">backups</span>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_custom_plan_user_estimate_setting"
                                 string="User Estimate per Worker"
                                 help="Concurrent users each worker can handle. Shown as recommendation on the pricing page.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_custom_plan_users_per_worker_min" string="Min (light usage)" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_custom_plan_users_per_worker_min" class="col-2"/>
                                    <span class="text-muted ms-1">users</span>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_custom_plan_users_per_worker_max" string="Max (heavy usage)" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_custom_plan_users_per_worker_max" class="col-2"/>
                                    <span class="text-muted ms-1">users</span>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_custom_plan_yearly_discount_setting"
                                 string="Yearly Discount"
                                 help="Percentage discount for yearly billing on custom plans.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_custom_plan_yearly_discount_pct" string="Discount" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_custom_plan_yearly_discount_pct" class="col-2"/>
                                    <span class="text-muted ms-1">%</span>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- ==================== Hosting Plan Builder ==================== -->
                    <block title="Hosting Plan Builder" name="saas_hosting_plan_container">
                        <setting id="saas_hosting_pricing_setting"
                                 string="Hosting Pricing"
                                 help="Price per worker and per GB for self-managed hosting plans.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_hosting_worker_price" string="Price per Worker" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_hosting_worker_price" class="col-2"/>
                                    <span class="text-muted ms-1">/ month</span>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_hosting_storage_price_per_gb" string="Price per GB" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_hosting_storage_price_per_gb" class="col-2"/>
                                    <span class="text-muted ms-1">/ month</span>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_hosting_workers_setting"
                                 string="Worker Limits"
                                 help="Min/max workers selectable by hosting customers.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_hosting_min_workers" string="Min Workers" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_hosting_min_workers" class="col-2"/>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_hosting_max_workers" string="Max Workers" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_hosting_max_workers" class="col-2"/>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_hosting_storage_setting"
                                 string="Storage Limits"
                                 help="Min/max storage (GB) selectable by hosting customers.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_hosting_min_storage" string="Min Storage" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_hosting_min_storage" class="col-2"/>
                                    <span class="text-muted ms-1">GB</span>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_hosting_max_storage" string="Max Storage" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_hosting_max_storage" class="col-2"/>
                                    <span class="text-muted ms-1">GB</span>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_hosting_resources_setting"
                                 string="Resource Allocation"
                                 help="CPU and RAM allocated per worker for hosting plans.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_hosting_cpu_per_worker" string="CPU per Worker" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_hosting_cpu_per_worker" class="col-2"/>
                                    <span class="text-muted ms-1">vCPU</span>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_hosting_ram_per_worker" string="RAM per Worker" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_hosting_ram_per_worker" class="col-2"/>
                                    <span class="text-muted ms-1">MB</span>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_hosting_backups_setting"
                                 string="Backups"
                                 help="Backup count range for hosting plans (scales with plan size).">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_hosting_min_backups" string="Smallest plan" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_hosting_min_backups" class="col-2"/>
                                    <span class="text-muted ms-1">backups</span>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_hosting_max_backups" string="Largest plan" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_hosting_max_backups" class="col-2"/>
                                    <span class="text-muted ms-1">backups</span>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_hosting_yearly_discount_setting"
                                 string="Yearly Discount"
                                 help="Percentage discount for yearly billing on hosting plans.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_hosting_yearly_discount_pct" string="Discount" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_hosting_yearly_discount_pct" class="col-2"/>
                                    <span class="text-muted ms-1">%</span>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_hosting_daily_backup_price_setting"
                                 string="Daily Backup Add-on"
                                 help="Optional add-on selectable at hosting checkout. Backs up every database on the instance daily; keeps the last 7 days per database.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_hosting_daily_backup_price" string="Monthly price" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_hosting_daily_backup_price" class="col-2"/>
                                    <span class="text-muted ms-1">/ month</span>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_hosting_snapshot_retention_surcharge" string="Retention surcharge" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_hosting_snapshot_retention_surcharge" class="col-2"/>
                                    <span class="text-muted ms-1">one-time on first activation after reactivation</span>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- ==================== Billing ==================== -->
                    <block title="Billing" name="saas_billing_container">
                        <setting id="saas_extra_storage_price_per_gb_setting"
                                 string="Extra Storage Pricing"
                                 help="Price charged per extra GB exceeding the plan storage limit. Added to renewal invoices. Set to 0 to suspend instances instead of charging.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_extra_storage_price_per_gb" string="Price per GB" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_extra_storage_price_per_gb" class="col-2"/>
                                    <span class="text-muted ms-1">/ billing cycle</span>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- ==================== Pricing Engine ==================== -->
                    <block title="Pricing Engine" name="saas_pricing_engine_container">
                        <setting id="saas_cost_floor_setting"
                                 string="Cost Floors (margin protection)"
                                 help="Minimum monthly cost charged per worker / per GB on CUSTOM configurations. The engine charges max(rate, floor), so cheap-resource + huge-storage configs can't be sold below cost. 0 = no floor (unchanged).">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_hosting_worker_floor" string="Hosting: per worker" class="col-4 col-lg-4 o_light_label"/>
                                    <field name="saas_hosting_worker_floor" class="col-2"/>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_hosting_storage_floor" string="Hosting: per GB" class="col-4 col-lg-4 o_light_label"/>
                                    <field name="saas_hosting_storage_floor" class="col-2"/>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_worker_floor" string="Services: per worker" class="col-4 col-lg-4 o_light_label"/>
                                    <field name="saas_worker_floor" class="col-2"/>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_storage_floor" string="Services: per GB" class="col-4 col-lg-4 o_light_label"/>
                                    <field name="saas_storage_floor" class="col-2"/>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_storage_block_setting"
                                 string="Storage Expansion Block"
                                 help="Storage above the plan allowance is sold/billed in whole blocks of this size (wired from S6) — keeps storage pricing predictable. Price 0 = not configured.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_storage_block_gb" string="Block size (GB)" class="col-4 col-lg-4 o_light_label"/>
                                    <field name="saas_storage_block_gb" class="col-2"/>
                                </div>
                                <div class="row mt8">
                                    <label for="saas_storage_block_price" string="Block price (monthly)" class="col-4 col-lg-4 o_light_label"/>
                                    <field name="saas_storage_block_price" class="col-2"/>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_snapshots_count_toward_storage_setting"
                                 string="Count Snapshots Toward Storage"
                                 help="ON (current): half the deduplicated snapshot footprint counts against the plan storage allowance. OFF (recommended): snapshots are covered solely by the Daily Backups add-on. Wired in S6.">
                            <field name="saas_snapshots_count_toward_storage"/>
                        </setting>
                        <setting id="saas_custom_min_is_nearest_tier_setting"
                                 string="Custom Price >= Nearest Tier"
                                 help="When on, a custom (slider) configuration is never priced below the nearest public tier with equal-or-greater resources. Protects tier value. Wired in S4.">
                            <field name="saas_custom_min_is_nearest_tier"/>
                        </setting>
                    </block>

                    <!-- ==================== Monitoring ==================== -->
                    <block title="Monitoring" name="saas_monitoring_container">
                        <setting id="saas_resource_usage_multiplier_setting"
                                 string="Resource Usage Multiplier"
                                 help="Multiplier applied to CPU and RAM measurements to estimate total usage including shared DB server overhead.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_resource_usage_multiplier" string="Multiplier" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_resource_usage_multiplier" class="col-2"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- ==================== Cloud Storage ==================== -->
                    <!-- One bucket for both daily backups (restic-encrypted)
                         and product snapshots — the snapshot lookup reads
                         these same saas_backup.* parameters. -->
                    <block title="Cloud Storage" name="saas_backup_storage_container">
                        <setting id="saas_backup_provider_setting"
                                 string="Cloud Provider"
                                 help="Cloud storage provider for daily backups and product snapshots (shared bucket).">
                            <field name="saas_backup_provider"/>
                        </setting>
                        <setting id="saas_backup_credentials_setting"
                                 string="Credentials"
                                 help="Authentication credentials for the storage provider."
                                 invisible="not saas_backup_provider">
                            <div class="content-group">
                                <div class="row mt8" invisible="saas_backup_provider == 'gcs'">
                                    <label for="saas_backup_access_key" string="Access Key" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_backup_access_key" class="col-4"/>
                                </div>
                                <div class="row mt8" invisible="saas_backup_provider == 'gcs'">
                                    <label for="saas_backup_secret_key" string="Secret Key" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_backup_secret_key" password="True" class="col-4"/>
                                </div>
                                <div class="row mt8" invisible="saas_backup_provider != 'gcs'">
                                    <label for="saas_backup_service_account_key_file" string="Service Account Key" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_backup_service_account_key_file"
                                           filename="saas_backup_service_account_key_filename"/>
                                    <field name="saas_backup_service_account_key_filename"
                                           invisible="1"/>
                                </div>
                            </div>
                        </setting>
                        <setting id="saas_backup_bucket_setting"
                                 string="Bucket"
                                 help="Bucket name, region, and endpoint. Used for both daily backups and product snapshots."
                                 invisible="not saas_backup_provider">
                            <div class="content-group">
                                <div class="row mt8">
                                    <label for="saas_backup_bucket_name" string="Bucket Name" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_backup_bucket_name" class="col-4"/>
                                </div>
                                <div class="row mt8" invisible="saas_backup_provider == 'gcs'">
                                    <label for="saas_backup_region" string="Region" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_backup_region" class="col-4" placeholder="e.g. us-east-1"/>
                                </div>
                                <div class="row mt8" invisible="saas_backup_provider in ('gcs', 'digitalocean')">
                                    <label for="saas_backup_endpoint" string="Endpoint URL" class="col-3 col-lg-3 o_light_label"/>
                                    <field name="saas_backup_endpoint" class="col-4"
                                           placeholder="https://s3.amazonaws.com"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>

    <!-- Action to open settings with saas_core module context -->
    <record id="action_saas_master_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'saas_core', 'bin_size': False}</field>
    </record>

</odoo>
