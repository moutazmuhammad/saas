<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="saas_addon_action" model="ir.actions.act_window">
        <field name="name">Add-ons</field>
        <field name="res_model">saas.addon</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a paid add-on</p>
            <p>Add-ons (e.g. Daily Snapshots) are summed into the price by the
               pricing engine. Set a flat monthly price, or point at a Settings
               config key for add-ons whose price already lives there.</p>
        </field>
    </record>

    <record id="saas_addon_view_list" model="ir.ui.view">
        <field name="name">saas.addon.list</field>
        <field name="model">saas.addon</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="applies_to"/>
                <field name="price_mode"/>
                <field name="monthly_price"/>
                <field name="price_per_block" optional="show"/>
                <field name="block_gb" optional="show"/>
                <field name="price_config_param" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="saas_addon_view_form" model="ir.ui.view">
        <field name="name">saas.addon.form</field>
        <field name="model">saas.addon</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="applies_to"/>
                            <field name="active"/>
                        </group>
                        <group string="Pricing">
                            <field name="price_mode"/>
                            <field name="monthly_price"
                                   invisible="price_mode == 'storage'"/>
                            <field name="price_per_block"
                                   invisible="price_mode == 'flat'"/>
                            <field name="block_gb"
                                   invisible="price_mode == 'flat'"/>
                            <field name="price_config_param"
                                   placeholder="e.g. saas_master.snapshot_price_per_gb"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Optional description"/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
