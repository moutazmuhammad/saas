<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="saas_instance_view_list" model="ir.ui.view">
        <field name="name">saas.instance.list</field>
        <field name="model">saas.instance</field>
        <field name="arch" type="xml">
            <list string="SaaS Instances"
                  decoration-success="state == 'running'"
                  decoration-danger="state in ('cancelled', 'cancelled_by_client', 'failed')"
                  decoration-warning="state == 'suspended'"
                  decoration-muted="state in ('draft', 'stopped')"
                  decoration-info="state == 'provisioning'">
                <field name="subdomain"/>
                <field name="saas_product_id" string="Service" optional="show"/>
                <field name="plan_id" optional="show"/>
                <field name="partner_id"/>
                <field name="odoo_version_id"/>
                <field name="docker_server_id"/>
                <field name="db_server_id"/>
                <field name="sale_order_id" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'running'"
                       decoration-danger="state in ('cancelled', 'cancelled_by_client', 'failed')"
                       decoration-warning="state == 'suspended'"
                       decoration-muted="state == 'stopped'"
                       decoration-info="state in ('draft', 'provisioning')"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="saas_instance_view_form" model="ir.ui.view">
        <field name="name">saas.instance.form</field>
        <field name="model">saas.instance</field>
        <field name="arch" type="xml">
            <form string="SaaS Instance">
                <header>
                    <!-- ===== Billing Flow ===== -->

                    <!-- Confirm & Bill: draft with a plan assigned (not trial).
                         Creates SO, confirms, invoices. Deploys automatically
                         once payment is received (or immediately if zero-amount). -->
                    <button name="action_confirm_and_bill"
                            string="Confirm &amp; Bill"
                            type="object" class="btn-primary"
                            icon="fa-check"
                            invisible="state != 'draft' or not plan_id or is_trial"/>

                    <!-- Mark as Paid: manual fallback (wire transfers, trials) -->
                    <button name="action_mark_as_paid"
                            string="Mark as Paid"
                            type="object" class="btn-secondary"
                            icon="fa-money"
                            invisible="state != 'pending_payment'"
                            groups="saas_core.group_saas_manager"/>

                    <!-- ===== Deployment ===== -->

                    <!-- Deploy: draft without plan, draft trial, or retry from failed -->
                    <button name="action_deploy" string="Deploy"
                            type="object" class="btn-primary"
                            icon="fa-play"
                            invisible="(state == 'draft' and plan_id and not is_trial) or state not in ('draft', 'failed')"/>

                    <!-- ===== Instance Operations ===== -->

                    <!-- Restart: when running, stopped, or suspended -->
                    <button name="action_restart" string="Restart"
                            type="object" icon="fa-refresh"
                            invisible="state not in ('running', 'stopped', 'suspended')"/>

                    <!-- Stop: only when running -->
                    <button name="action_stop" string="Stop"
                            type="object" icon="fa-stop"
                            invisible="state != 'running'"
                            confirm="Are you sure you want to stop this instance?"/>

                    <!-- Suspend: when running -->
                    <button name="action_suspend" string="Suspend"
                            type="object" icon="fa-pause"
                            invisible="state != 'running'"/>

                    <!-- Redeploy: when running, stopped, or suspended -->
                    <button name="action_redeploy" string="Redeploy"
                            type="object" icon="fa-rocket"
                            invisible="state not in ('running', 'stopped', 'suspended')"
                            confirm="This will stop and restart the container (volumes are kept). Are you sure?"/>

                    <!-- Config: when running -->
                    <button name="action_config" string="Config"
                            type="object" icon="fa-cog"
                            invisible="state != 'running'"/>

                    <!-- Docker Compose: when running -->
                    <button name="action_docker_compose" string="Docker Compose"
                            type="object" icon="fa-docker"
                            invisible="state != 'running'"/>

                    <!-- Live Logs: when running -->
                    <button name="action_view_logs" string="Logs"
                            type="object" icon="fa-file-text-o"
                            invisible="state != 'running'"/>

                    <!-- Create Backup: when running -->
                    <button name="action_create_backup" string="Create Backup"
                            type="object"
                            invisible="state != 'running'"/>

                    <!-- Delete: when running, stopped, failed, or suspended -->
                    <button name="action_delete_instance" string="Delete"
                            type="object" class="btn-danger"
                            invisible="state not in ('running', 'stopped', 'failed', 'suspended')"
                            confirm="This will permanently delete the container, volumes, network, database, and all data. Are you sure?"/>

                    <!-- Reset to Draft: from failed, cancelled, pending_payment, or paid -->
                    <button name="action_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('failed', 'cancelled', 'pending_payment', 'paid')"/>

                    <!-- Statusbar -->
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending_payment,paid,provisioning,running"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_order"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart"
                                invisible="not sale_order_id">
                            <field name="sale_order_count" widget="statinfo"
                                   string="Sale Order"/>
                        </button>
                        <button name="action_view_invoices"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-pencil-square-o"
                                invisible="invoice_count == 0">
                            <field name="invoice_count" widget="statinfo"
                                   string="Invoices"/>
                        </button>
                    </div>
                    <group>
                        <!-- Left Column -->
                        <group>
                            <field name="subdomain"/>
                            <field name="domain_id" options="{'no_open': True}"/>
                            <field name="saas_product_id" string="Service"/>
                            <field name="plan_id" domain="[('saas_product_id', '=', saas_product_id)]"/>
                            <field name="partner_id"/>
                            <field name="url" widget="url"/>
                            <field name="is_trial" widget="boolean_toggle" readonly="1"/>
                            <field name="next_invoice_date" readonly="1"/>
                            <field name="odoo_version_id" readonly="id"/>
                        </group>
                        <!-- Right Column -->
                        <group>
                            <field name="docker_server_id"/>
                            <field name="db_server_id"/>
                            <field name="xmlrpc_port"/>
                            <field name="longpolling_port"/>
                            <field name="admin_password" password="True"/>
                            <field name="db_user"/>
                            <field name="db_password" password="True"/>
                        </group>
                    </group>

                    <!-- Resource Usage -->
                    <div class="d-flex align-items-center"
                         invisible="state != 'running'">
                        <h2 class="me-3">Resource Usage</h2>
                        <button name="action_refresh_usage" string="Refresh"
                                type="object" icon="fa-refresh"
                                class="btn-link"/>
                    </div>
                    <group invisible="state != 'running'">
                        <group>
                            <field name="cpu_usage"/>
                            <field name="ram_usage"/>
                            <field name="ram_percent"/>
                        </group>
                        <group>
                            <field name="disk_usage"/>
                            <field name="db_size"/>
                            <field name="total_storage"/>
                            <field name="usage_last_updated"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Backups">
                            <field name="backup_ids" nolabel="1">
                                <list create="0" edit="0" delete="0"
                                      decoration-success="state == 'done'"
                                      decoration-danger="state == 'failed'"
                                      decoration-info="state == 'running'">
                                    <field name="name"/>
                                    <field name="create_date" string="Date"/>
                                    <field name="size_mb"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'done'"
                                           decoration-danger="state == 'failed'"
                                           decoration-info="state == 'running'"/>
                                    <field name="download_url" widget="url"
                                           string="Download"
                                           invisible="state != 'done'"/>
                                    <field name="download_url_expiry" string="Link Expires"
                                           invisible="state != 'done'"/>
                                    <button name="action_download" type="object"
                                            string="Download" icon="fa-download"
                                            invisible="state != 'done'"/>
                                    <button name="action_delete_backup" type="object"
                                            string="Delete" icon="fa-trash"
                                            confirm="This will permanently delete this backup from cloud storage. Continue?"/>
                                    <field name="error_message" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Custom Repos">
                            <field name="repo_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="repo_url" placeholder="https://github.com/user/repo.git"/>
                                    <field name="branch"/>
                                    <field name="github_token" password="True"
                                           placeholder="ghp_... (private repos only)"/>
                                    <field name="addons_subdir"
                                           placeholder="e.g. addons/ (optional)"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'cloned'"
                                           decoration-danger="state == 'error'"
                                           decoration-info="state == 'pending'"/>
                                    <field name="last_pull"/>
                                    <button name="action_clone_repo" type="object"
                                            string="Clone" icon="fa-clone"
                                            invisible="state == 'cloned'"/>
                                    <button name="action_pull_repo" type="object"
                                            string="Pull" icon="fa-download"
                                            invisible="state != 'cloned'"/>
                                    <button name="action_clone_repo" type="object"
                                            string="Re-clone" icon="fa-refresh"
                                            invisible="state != 'error'"/>
                                    <button name="action_remove_repo" type="object"
                                            string="Remove" icon="fa-trash"
                                            confirm="Remove this repo from the server?"/>
                                    <field name="error_message" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Extra Configuration">
                            <field name="extra_config" nolabel="1"
                                   placeholder="key = value (one per line)"/>
                        </page>
                        <page string="Provisioning Log"
                              invisible="not provisioning_log">
                            <field name="provisioning_log" readonly="1"
                                   nolabel="1"/>
                        </page>
                        <page string="Cancellation"
                              invisible="not cancellation_reason">
                            <field name="cancellation_reason" readonly="1"
                                   nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    <!-- Action -->
    <record id="saas_instance_action" model="ir.actions.act_window">
        <field name="name">SaaS Instances</field>
        <field name="res_model">saas.instance</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first SaaS instance
            </p>
        </field>
    </record>

</odoo>
